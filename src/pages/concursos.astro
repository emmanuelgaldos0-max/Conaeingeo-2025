---
import Layout from "../layouts/Layout.astro";
import { existsSync, readdirSync } from "node:fs";
import { basename, extname } from "node:path";

const flyerDir = new URL("../../public/Concursos", import.meta.url);
const flyerFiles = readdirSync(flyerDir)
    .filter((file) => /\.(png|jpe?g|webp|avif)$/i.test(file))
    .sort((a, b) => a.localeCompare(b, undefined, { sensitivity: "base" }));

const titleOverrides = {
    "cartografiado geologico subterraneo": "Cartografiado Geológico Subterráneo",
    "cartografiado geologico superficial": "Cartografiado Geológico Superficial",
    "debate geologico": "Debate Geológico",
    "elaboracion de columna estratigrafica y seccion geologica": "Elaboración de Columna Estratigráfica y Sección Geológica",
    "fotointerpretacion geologica": "Fotointerpretación Geológica",
    "geomecanica de rocas": "Geomecánica de Rocas",
    "logueo geologico": "Logueo Geológico",
    "reconocimiento paleontologico": "Reconocimiento Paleontológico",
};

const normalizeKey = (text: string) =>
    text
        .toLowerCase()
        .normalize("NFD")
        .replace(/\p{Diacritic}/gu, "")
        .replace(/\s+/g, " ")
        .trim();

const pdfDir = new URL("../../public/Concursos/PDFs", import.meta.url);
const pdfFiles = existsSync(pdfDir)
    ? readdirSync(pdfDir).filter((file) => /\.pdf$/i.test(file))
    : [];
const pdfEntries = pdfFiles.map((file) => {
    const name = basename(file, extname(file));
    const key = normalizeKey(name);
    return {
        key,
        href: `/Concursos/PDFs/${encodeURI(file)}`,
    };
});

const findPdfForKey = (flyerKey: string) => {
    const exact = pdfEntries.find((entry) => entry.key === flyerKey);
    if (exact) {
        return exact.href;
    }

    const containsFlyer = pdfEntries.find((entry) => entry.key.includes(flyerKey));
    if (containsFlyer) {
        return containsFlyer.href;
    }

    const flyerContains = pdfEntries.find((entry) => flyerKey.includes(entry.key));
    return flyerContains ? flyerContains.href : undefined;
};

const flyers = flyerFiles.map((file) => {
    const name = basename(file, extname(file));
    const cleaned = name.replace(/[_]+/g, " ").replace(/\s+/g, " ").trim();
    const key = normalizeKey(cleaned);
    const pretty = titleOverrides[key]
        ? titleOverrides[key]
        : cleaned.length > 0
              ? cleaned
                    .split(" ")
                    .map((word) => (word ? word[0].toUpperCase() + word.slice(1).toLowerCase() : ""))
                    .join(" ")
              : "Flyer";

    return {
        key,
        title: pretty,
        src: `/Concursos/${encodeURI(file)}`,
        pdfHref: findPdfForKey(key),
    };
});
---

<Layout title="Concursos - CONAEINGEO 2026">
    <section class="page-header concursos-hero">
        <div class="container">
            <p class="eyebrow">Galería de concursos</p>
            <p class="lead">
                Únete al espíritu competitivo de los concursos oficiales del XV CONAEINGEO: cartografía, 
                debate, reconocimiento geológico, fotografía, modelamiento y más.
            </p>
        </div>
    </section>

    <section class="section flyers-section">
        <div class="container">
            {flyers.length > 0 ? (
                <div class="flyers-grid">
                    {flyers.map((flyer) => (
                        <article class="flyer-card">
                            <div class="flyer-frame">
                                <img src={flyer.src} alt={`Flyer ${flyer.title}`} loading="lazy" />
                            </div>
                            <div class="flyer-meta">
                                <h3>{flyer.title}</h3>
                                {!flyer.pdfHref && <p>Detalles próximamente</p>}
                                {flyer.pdfHref && (
                                    <div class="flyer-actions">
                                        <a
                                            class="flyer-download-btn"
                                            href={flyer.pdfHref}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                        >
                                            Descarga las bases del concurso
                                        </a>
                                    </div>
                                )}
                            </div>
                        </article>
                    ))}
                </div>
            ) : (
                <p class="empty-state">Estamos preparando los flyers para esta sección.</p>
            )}
        </div>
    </section>
</Layout>

<style>
    .concursos-hero {
        background: var(--gradient-hero);
        color: var(--color-white);
        padding: 8rem 0 4rem;
        text-align: center;
        margin-top: 80px;
    }

    .concursos-hero .container {
        position: relative;
        z-index: 1;
        text-align: center;
        max-width: 900px;
    }

    .eyebrow {
        letter-spacing: 0.3em;
        text-transform: uppercase;
        font-size: 0.85rem;
        margin-bottom: 1rem;
        color: rgba(255, 255, 255, 0.85);
    }

    .concursos-hero .lead {
        font-size: 1.25rem;
        color: rgba(255, 255, 255, 0.9);
        max-width: 600px;
        margin: 0 auto;
    }

    .flyers-section {
        background: var(--color-lighter);
    }

    .flyers-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 2.5rem;
        margin: 2rem auto 0;
        max-width: 1200px;
    }

    .flyer-card {
        background: var(--color-white);
        border-radius: var(--radius-lg);
        padding: 1.25rem;
        box-shadow: var(--shadow-md);
        display: flex;
        flex-direction: column;
        gap: 1rem;
        border: 1px solid rgba(30, 58, 138, 0.12);
        transition: transform var(--transition-fast), box-shadow var(--transition-fast);
    }

    .flyer-card:hover {
        transform: translateY(-6px);
        box-shadow: var(--shadow-xl);
    }

    .flyer-frame {
        flex: 1;
        min-height: 420px;
        border-radius: var(--radius-md);
        overflow: hidden;
        background: var(--color-light);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .flyer-frame img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
        transition: transform var(--transition-slow);
    }

    .flyer-card:hover .flyer-frame img {
        transform: scale(1.02);
    }

    .flyer-meta h3 {
        font-size: 1.1rem;
        color: var(--color-primary);
        margin-bottom: 0.35rem;
    }

    .flyer-meta p {
        margin: 0;
        font-size: 0.9rem;
        color: var(--color-text-light);
    }

    .flyer-actions {
        margin-top: 0.75rem;
    }

    .flyer-download-btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.6rem 1.2rem;
        border-radius: var(--radius-md);
        border: 2px solid var(--color-primary);
        background: var(--color-primary);
        color: var(--color-white);
        font-size: 0.95rem;
        font-weight: 600;
        text-decoration: none;
        transition: transform var(--transition-fast), box-shadow var(--transition-fast);
    }

    .flyer-download-btn:hover,
    .flyer-download-btn:focus-visible {
        transform: translateY(-1px);
        box-shadow: var(--shadow-md);
    }

    .empty-state {
        text-align: center;
        padding: 3rem 0;
        font-size: 1.1rem;
        color: var(--color-text-light);
    }

    @media (max-width: 768px) {
        .flyer-frame {
            min-height: 280px;
        }

        .flyers-grid {
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        }
    }
</style>
