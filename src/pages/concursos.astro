---
import Layout from "../layouts/Layout.astro";
import { readdirSync } from "node:fs";
import { basename, extname } from "node:path";

const flyerDir = new URL("../../public/Concursos", import.meta.url);
const flyerFiles = readdirSync(flyerDir)
    .filter((file) => /\.(png|jpe?g|webp|avif)$/i.test(file))
    .sort((a, b) => a.localeCompare(b, undefined, { sensitivity: "base" }));

const flyers = flyerFiles.map((file) => {
    const name = basename(file, extname(file));
    const cleaned = name.replace(/[_]+/g, " ").replace(/\s+/g, " ").trim();
    const pretty =
        cleaned.length > 0
            ? cleaned
                  .split(" ")
                  .map((word) => (word ? word[0].toUpperCase() + word.slice(1).toLowerCase() : ""))
                  .join(" ")
            : "Flyer";

    return {
        title: pretty,
        src: `/Concursos/${encodeURI(file)}`,
    };
});
---

<Layout title="Concursos - CONAEINGEO 2026">
    <section class="page-header concursos-hero">
        <div class="container">
            <p class="eyebrow">Galería de concursos</p>
            <h1>Concursos</h1>
            <p class="lead">
                Cada poster resume el espíritu competitivo de los concursos oficiales del XV CONAEINGEO: cartografía, 
                debate, reconocimiento geológico, fotografía, modelamiento y más. Usa esta galería para repasar el diseño 
                visual, ubicaciones y fechas clave de las pruebas que pondrán a prueba tu conocimiento y creatividad.
            </p>
        </div>
    </section>

    <section class="section flyers-section">
        <div class="container">
            {flyers.length > 0 ? (
                <div class="flyers-grid">
                    {flyers.map((flyer) => (
                        <article class="flyer-card">
                            <div class="flyer-frame">
                                <img src={flyer.src} alt={`Flyer ${flyer.title}`} loading="lazy" />
                            </div>
                            <div class="flyer-meta">
                                <h3>{flyer.title}</h3>
                                <p>Poster vertical del concurso</p>
                            </div>
                        </article>
                    ))}
                </div>
            ) : (
                <p class="empty-state">Estamos preparando los flyers para esta sección.</p>
            )}
        </div>
    </section>
</Layout>

<style>
    .concursos-hero {
        position: relative;
        padding: 6rem 0 4rem;
        background: linear-gradient(135deg, rgba(30, 58, 138, 0.94), rgba(249, 115, 22, 0.85));
        color: var(--color-white);
        overflow: hidden;
    }

    .concursos-hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background: radial-gradient(circle at 20% 20%, rgba(29, 78, 216, 0.45), transparent 40%),
            radial-gradient(circle at 80% 30%, rgba(248, 113, 113, 0.35), transparent 35%),
            rgba(15, 23, 42, 0.5);
        mix-blend-mode: multiply;
        z-index: 0;
    }

    .concursos-hero .container {
        position: relative;
        z-index: 1;
        text-align: center;
        max-width: 900px;
    }

    .eyebrow {
        letter-spacing: 0.3em;
        text-transform: uppercase;
        font-size: 0.85rem;
        margin-bottom: 1rem;
        color: rgba(255, 255, 255, 0.85);
    }

    .concursos-hero h1 {
        font-size: clamp(2.5rem, 5vw, 3.75rem);
        margin-bottom: 1.25rem;
        text-shadow: 0 12px 20px rgba(15, 23, 42, 0.55);
    }

    .concursos-hero .lead {
        font-size: 1.15rem;
        line-height: 1.7;
        color: rgba(255, 255, 255, 0.95);
        text-shadow: 0 10px 18px rgba(15, 23, 42, 0.45);
    }

    .flyers-section {
        background: var(--color-lighter);
    }

    .flyers-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 2.5rem;
        margin: 2rem auto 0;
        max-width: 1200px;
    }

    .flyer-card {
        background: var(--color-white);
        border-radius: var(--radius-lg);
        padding: 1.25rem;
        box-shadow: var(--shadow-md);
        display: flex;
        flex-direction: column;
        gap: 1rem;
        border: 1px solid rgba(30, 58, 138, 0.12);
        transition: transform var(--transition-fast), box-shadow var(--transition-fast);
    }

    .flyer-card:hover {
        transform: translateY(-6px);
        box-shadow: var(--shadow-xl);
    }

    .flyer-frame {
        flex: 1;
        min-height: 420px;
        border-radius: var(--radius-md);
        overflow: hidden;
        background: var(--color-light);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .flyer-frame img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
        transition: transform var(--transition-slow);
    }

    .flyer-card:hover .flyer-frame img {
        transform: scale(1.02);
    }

    .flyer-meta h3 {
        font-size: 1.1rem;
        color: var(--color-primary);
        margin-bottom: 0.35rem;
    }

    .flyer-meta p {
        margin: 0;
        font-size: 0.9rem;
        color: var(--color-text-light);
    }

    .empty-state {
        text-align: center;
        padding: 3rem 0;
        font-size: 1.1rem;
        color: var(--color-text-light);
    }

    @media (max-width: 768px) {
        .flyer-frame {
            min-height: 280px;
        }

        .flyers-grid {
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
        }
    }
</style>
