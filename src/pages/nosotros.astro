<style>
    .page-header {
        background: var(--gradient-hero);
        color: var(--color-white);
        padding: 8rem 0 4rem;
        text-align: center;
        margin-top: 80px;
    }

    .page-header h1 {
        color: var(--color-white);
        margin-bottom: 1rem;
    }

    .page-header p {
        font-size: 1.25rem;
        color: rgba(255, 255, 255, 0.9);
        max-width: 600px;
        margin: 0 auto;
    }

    .content-grid {
        display: grid;
        grid-template-columns: 2fr 1fr;
        gap: 3rem;
        margin-top: 3rem;
    }

    .main-content h2 {
        color: var(--color-primary);
        margin-top: 2.5rem;
        margin-bottom: 1rem;
    }

    .main-content h2:first-child {
        margin-top: 0;
    }

    .main-content p {
        margin-bottom: 1.5rem;
        line-height: 1.8;
    }

    .sidebar {
        position: sticky;
        top: 120px;
        align-self: start;
    }

    .info-card,
    .cta-card {
        margin-bottom: 2rem;
    }

    .info-card h3,
    .cta-card h3 {
        color: var(--color-dark);
        margin-bottom: 1.5rem;
    }

    .info-list {
        list-style: none;
        padding: 0;
    }

    .info-list li {
        display: flex;
        gap: 1rem;
        align-items: flex-start;
        margin-bottom: 1.5rem;
        padding-bottom: 1.5rem;
        border-bottom: 1px solid var(--color-light);
    }

    .info-list li:last-child {
        border-bottom: none;
        margin-bottom: 0;
        padding-bottom: 0;
    }

    .info-list i {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: var(--gradient-primary);
        color: var(--color-white);
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        font-size: 1.125rem;
    }

    .info-list strong {
        display: block;
        color: var(--color-dark);
        margin-bottom: 0.25rem;
    }

    .info-list span {
        display: block;
        color: var(--color-text-light);
        font-size: 0.95rem;
    }

    .cta-card {
        background: var(--gradient-primary);
        color: var(--color-white);
        text-align: center;
    }

    .cta-card h3 {
        color: var(--color-white);
    }

    .cta-card p {
        color: rgba(255, 255, 255, 0.95);
        margin-bottom: 1.5rem;
    }

    .cta-card .btn {
        background: var(--color-white);
        color: var(--color-primary);
    }

    .cta-card .btn:hover {
        background: var(--color-light);
    }

    @media (max-width: 1024px) {
        .content-grid {
            grid-template-columns: 1fr;
        }

        .sidebar {
            position: static;
        }
    }

    @media (max-width: 768px) {
        .page-header {
            padding: 6rem 0 3rem;
        }
    }
</style>
