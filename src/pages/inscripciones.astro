                                </li>
                            </ul>
                            <a href="#" class="btn btn-primary">Inscribirse</a>
                        </div>
 -->
                        <div class="card pricing-card pass-card pichu-card">
                            <div class="pass-visual">
                                <img src="/entradas/pichu pichu.png" alt="Experiencia Pass Pichu Pichu" />
                            </div>
                            <div class="card-header">
                                
                                <div class="price">S/ 240</div>
                                <div class="price-note">Tarifa estudiante</div>
                            </div>
                            <ul class="benefits-list">
                                <li>
                                    <i class="fas fa-check"></i> Acceso oficial al XV CONAEINGEO
                                </li>
                                <li>
                                    <i class="fas fa-check"></i> Certificado de participación
                                </li>
                                <li>
                                    <i class="fas fa-check"></i> Explorer Kit XV CONAEINGEO
                                </li>
                                <li>
