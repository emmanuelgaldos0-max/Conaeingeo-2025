---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Inscripciones - CONAEINGEO 2026">
    <section class="page-header">
        <div class="container">
            <h1>Inscripciones</h1>
            <p>Únete al evento de geologia  más importante del Perú</p>
        </div>
    </section>

    <section class="section">
        <div class="container">
            <div class="content-wrapper">
                <div class="registration-info">
                    <h2>Inversión y Beneficios</h2>
                    <p>
                        Participa en el XV CONAEINGEO – Arequipa 2026 y forma
                        parte de uno de los encuentros académicos más importantes
                        para estudiantes y profesionales de Ingeniería Geológica.
                        La inscripción te permitirá acceder a actividades
                        académicas, espacios de integración y experiencias de
                        aprendizaje vinculadas a las geociencias.
                    </p>

                    <!-- BOTONES -->
                    <div class="toggle-user-type">
                        <button id="btn-estudiante" class="toggle-btn active">Estudiante</button>
                        <button id="btn-egresado" class="toggle-btn">Egresado</button>
                    </div>

                    <div class="pricing-cards">
                        <!-- COSTO -->
                        <div class="card pricing-card pass-card costo-card">
                            <div class="pass-visual">
                                <img src="/entradas/4.png" alt="Pass por confirmar" />
                            </div>
                            <div class="card-header">
                                <div class="price">Próximamente</div>
                                <div class="price-note" id="note-prox">Precio estudiante por confirmar</div>
                            </div>
                            <ul class="benefits-list">
                                <li><i class="fas fa-check"></i> Acceso oficial al XV CONAEINGEO</li>
                                <li><i class="fas fa-check"></i> Certificado de participación</li>
                                <li><i class="fas fa-check"></i> Acceso a la Feria Tecnológica</li>
                                <li><i class="fas fa-check"></i> Beneficios adicionales según la pieza promocional oficial</li>
                            </ul>
                            <a class="btn btn-secondary"></a>
                        </div>

                        <!-- CHACHANI -->
                        <div class="card pricing-card pass-card chachani-card">
                            <div class="pass-visual">
                                <img src="/entradas/Chachani.png" alt="Descubre Pass Chachani" />
                            </div>
                            <div class="card-header">
                                <div class="price" id="price-chachani">S/ 140</div>
                                <div class="price-note" id="note-chachani">Tarifa estudiante</div>
                            </div>
                            <ul class="benefits-list">
                                <li><i class="fas fa-check"></i> Acceso oficial al XV CONAEINGEO</li>
                                <li><i class="fas fa-check"></i> Certificado de participación</li>
                                <li><i class="fas fa-check"></i> Explorer Kit XV CONAEINGEO</li>
                                <li><i class="fas fa-check"></i> Acceso a la Feria Tecnológica & Expo Empresarial</li>
                                <li><i class="fas fa-check"></i> 50% de descuento en cursos electivos especializados</li>
                            </ul>

                            <!-- BOTÓN CON LINK -->
                            <a href="https://docs.google.com/forms/d/1vqjE0RsX_AcpabI8t0iistfftEeB1VB8q6q8Am91JSY/edit"
                               target="_blank"
                               class="btn btn-secondary btn-inscribete">
                               Inscríbete
                            </a>
                        </div>

                        <!-- PICHO PICHO -->
                        <div class="card pricing-card pass-card pichu-card">
                            <div class="pass-visual">
                                <img src="/entradas/pichu pichu.png" alt="Experiencia Pass Pichu Pichu" />
                            </div>
                            <div class="card-header">
                                <div class="price" id="price-pichu">S/ 240</div>
                                <div class="price-note" id="note-pichu">Tarifa estudiante</div>
                            </div>
                            <ul class="benefits-list">
                                <li><i class="fas fa-check"></i> Acceso oficial al XV CONAEINGEO</li>
                                <li><i class="fas fa-check"></i> Certificado de participación</li>
                                <li><i class="fas fa-check"></i> Explorer Kit XV CONAEINGEO</li>
                                <li><i class="fas fa-check"></i> Acceso a la Feria Tecnológica</li>
                                <li><i class="fas fa-check"></i> Visita técnica a una unidad minera</li>
                                <li><i class="fas fa-check"></i> City tour panorámico en Mirabus por la ciudad de Arequipa</li>
                                <li><i class="fas fa-check"></i> 50% de descuento en cursos electivos especializados</li>
                            </ul>

                            <!-- BOTÓN CON LINK -->
                            <a href="https://docs.google.com/forms/d/1k0q8QTKf-6t96t4Or9VnhplKcYNugbZwaJXyXLgkT-M/edit"
                               target="_blank"
                               class="btn btn-secondary btn-inscribete">
                               Inscríbete
                            </a>
                        </div>
                    </div>

                    <!-- SCRIPT -->
                    <script>
                        const btnEst = document.getElementById("btn-estudiante");
                        const btnEgr = document.getElementById("btn-egresado");

                        const priceChachani = document.getElementById("price-chachani");
                        const pricePichu = document.getElementById("price-pichu");

                        const noteChachani = document.getElementById("note-chachani");
                        const notePichu = document.getElementById("note-pichu");
                        const noteProx = document.getElementById("note-prox");

                        btnEst.addEventListener("click", () => {
                            priceChachani.textContent = "S/ 140";
                            pricePichu.textContent = "S/ 240";

                            noteChachani.textContent = "Tarifa estudiante";
                            notePichu.textContent = "Tarifa estudiante";
                            noteProx.textContent = "Precio estudiante por confirmar";

                            btnEst.classList.add("active");
                            btnEgr.classList.remove("active");
                        });

                        btnEgr.addEventListener("click", () => {
                            priceChachani.textContent = "S/ 170";
                            pricePichu.textContent = "S/ 270";

                            noteChachani.textContent = "Tarifa egresado";
                            notePichu.textContent = "Tarifa egresado";
                            noteProx.textContent = "Precio egresado por confirmar";

                            btnEgr.classList.add("active");
                            btnEst.classList.remove("active");
                        });
                    </script>

                    <style>
                        .toggle-user-type {
                            margin: 20px 0;
                            display: flex;
                            gap: 10px;
                        }

                        .toggle-btn {
                            padding: 14px 28px;
                            font-size: 16px;
                            border: 2px solid #ccc;
                            background: white;
                            cursor: pointer;
                            border-radius: 10px;
                            font-weight: 700;
                            transition: 0.3s;
                        }

                        .toggle-btn.active {
                            background: #1e3a8a;
                            color: white;
                            border-color: #1e3a8a;
                        }
                    </style>

                </div>
            </div>
        </div>
    </section>
</Layout>


<style>
    .page-header {
        background: var(--gradient-hero);
        color: var(--color-white);
        padding: 8rem 0 4rem;
        text-align: center;
        margin-top: 80px;
    }

    .page-header h1 {
        color: var(--color-white);
        margin-bottom: 1rem;
    }

    .page-header p {
        font-size: 1.25rem;
        color: rgba(255, 255, 255, 0.9);
        max-width: 600px;
        margin: 0 auto;
    }

    .toggle-btn {
        padding: 14px 28px;
        font-size: 16px;
        border: 2px solid #ccc;
        background: white;
        cursor: pointer;
        border-radius: 10px;
        font-weight: 700;
        transition: 0.3s;
    }


    /* estructura del card */
    .pricing-card {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    /* contenedor del botón */
    .btn-container {
        margin-top: auto;
        padding: 20px;
    }

    /* botón visible siempre */
    .btn-inscribete {
        display: block;
        width: 100%;
        text-align: center;
        padding: 16px;
        background: #1e3a8a;
        color: white;
        font-weight: 800;
        border-radius: 12px;
        text-decoration: none;
        transition: 0.3s;
    }

    /* hover */
    .btn-inscribete:hover {
        transform: scale(1.05);
        background: #162d6b;
    }

    /* 🔥 elimina cualquier ocultamiento global */
    .pricing-card .btn,
    .pricing-card:hover .btn {
        opacity: 1 !important;
        transform: none !important;
    }

    .content-wrapper {
        max-width: 1200px;
        margin: 3rem auto;
    }

    .registration-info h2 {
        color: var(--color-primary);
        margin-top: 3rem;
        margin-bottom: 1.5rem;
    }

    .registration-info h2:first-of-type {
        margin-top: 0;
    }

    .pricing-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
        margin: 3rem 0;
    }

    .pricing-card {
        position: relative;
        text-align: center;
        transition: all var(--transition-normal);
        overflow: hidden;
    }

    .pricing-card:hover {
        transform: translateY(-10px);
        box-shadow: var(--shadow-xl);
    }

    .pricing-card.featured {
        border: 3px solid var(--color-primary);
        transform: scale(1.05);
    }

    .pass-visual {
        width: 100%;
        aspect-ratio: 16 / 10;
        overflow: hidden;
        background: var(--color-light);
        border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    }

    .pass-visual img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        display: block;
        transform: none;
    }

    .featured-badge {
        position: absolute;
        top: -15px;
        left: 50%;
        transform: translateX(-50%);
        background: var(--gradient-primary);
        color: var(--color-white);
        padding: 0.5rem 1.5rem;
        border-radius: var(--radius-full);
        font-weight: 700;
        font-size: 0.875rem;
        box-shadow: var(--shadow-md);
    }

    .card-header {
        padding: 2rem;
        background: var(--gradient-primary);
        color: var(--color-white);
        border-radius: 0;
    }

    .pass-card.costo-card .card-header {
        background: linear-gradient(135deg, #475569 0%, #64748b 100%);
    }

    .pass-card.costo-card {
        order: 2;
    }

    .pass-card.chachani-card .card-header {
        background: linear-gradient(135deg, #0f57c3 0%, #1d74e7 100%);
    }

    .pass-card.chachani-card {
        order: 1;
    }

    .pass-card.misti-card .card-header {
        background: linear-gradient(135deg, #b9794c 0%, #c98b5d 100%);
    }

    .pass-card.pichu-card .card-header {
        background: linear-gradient(135deg, #7c45f3 0%, #9a63ff 100%);
    }

    .pass-card.pichu-card {
        order: 3;
    }

    .pass-card.costo-card .price {
        font-size: clamp(1.6rem, 6.2vw, 2.2rem);
        line-height: 1.15;
        overflow-wrap: anywhere;
    }

    .card-header h3 {
        color: var(--color-white);
        margin-bottom: 1rem;
        font-size: 1.5rem;
    }

    .price {
        font-size: 2.5rem;
        font-weight: 900;
        font-family: var(--font-heading);
    }

    .price-note {
        font-size: 0.875rem;
        opacity: 0.9;
        margin-top: 0.5rem;
    }

    .benefits-list {
        list-style: none;
        padding: 2rem;
        text-align: left;
    }

    .benefits-list li {
        display: flex;
        align-items: start;
        gap: 0.75rem;
        margin-bottom: 1rem;
        font-size: 0.95rem;
    }

    .benefits-list i {
        color: var(--color-primary);
        margin-top: 0.25rem;
        flex-shrink: 0;
    }

    .pricing-card .btn {
        margin: 0 2rem 2rem 2rem;
        width: calc(100% - 4rem);
    }

    .steps-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 2rem;
        margin: 2rem 0;
    }

    .step-card {
        text-align: center;
        padding: 2rem;
        border: 2px solid var(--color-light);
        border-radius: var(--radius-lg);
        transition: all var(--transition-normal);
    }

    .step-card:hover {
        border-color: var(--color-primary);
        box-shadow: var(--shadow-md);
    }

    .step-number {
        width: 60px;
        height: 60px;
        margin: 0 auto 1rem;
        background: var(--gradient-primary);
        color: var(--color-white);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.75rem;
        font-weight: 900;
        font-family: var(--font-heading);
    }

    .step-card h3 {
        color: var(--color-dark);
        margin-bottom: 1rem;
    }

    .info-section {
        margin: 4rem 0;
    }

    .faq-item {
        padding: 2rem;
        background: var(--color-white);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-md);
        margin-bottom: 1.5rem;
        border-left: 4px solid var(--color-primary);
    }

    @media (max-width: 768px) {
        .page-header {
            padding: 6rem 0 3rem;
        }

        .pricing-cards {
            grid-template-columns: 1fr;
        }

        .pricing-card.featured {
            transform: scale(1);
        }

        .pass-visual {
            aspect-ratio: 16 / 10;
        }
    }
</style>
