---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Inscripciones - CONAIGEO 2026">
    <!-- Page Header -->
    <section class="page-header">
        <div class="container">
            <h1>Inscripciones</h1>
            <p>Únete al evento más importante de minería del sur del Perú</p>
        </div>
    </section>

    <!-- Registration Content -->
    <section class="section">
        <div class="container">
            <div class="content-wrapper">
                <div class="registration-info">
                    <h2>Inversión y Beneficios</h2>
                    <p>
                        Lorem ipsum dolor sit amet, consectetur adipiscing elit.
                        Inscríbete ahora y asegura tu lugar en CONAIGEO 2026.
                        Sed do eiusmod tempor incididunt ut labore et dolore
                        magna aliqua.
                    </p>

                    <div class="pricing-cards">
                        <div class="card pricing-card">
                            <div class="card-header">
                                <h3>Estudiante</h3>
                                <div class="price">S/ 150</div>
                            </div>
                            <ul class="benefits-list">
                                <li>
                                    <i class="fas fa-check"></i> Acceso a todas las
                                    conferencias
                                </li>
                                <li>
                                    <i class="fas fa-check"></i> Material digital
                                    del congreso
                                </li>
                                <li>
                                    <i class="fas fa-check"></i> Certificado de participación
                                </li>
                                <li>
                                    <i class="fas fa-check"></i> Coffee breaks
                                </li>
                                <li>
                                    <i class="fas fa-check"></i> Networking con profesionales
                                </li>
                            </ul>
                            <a href="#" class="btn btn-secondary">Inscribirse</a
                            >
                        </div>

                        <div class="card pricing-card featured">
                            <div class="featured-badge">Recomendado</div>
                            <div class="card-header">
                                <h3>Profesional</h3>
                                <div class="price">S/ 350</div>
                            </div>
                            <ul class="benefits-list">
                                <li>
                                    <i class="fas fa-check"></i> Todo lo del paquete
                                    Estudiante
                                </li>
                                <li>
                                    <i class="fas fa-check"></i> Acceso a talleres
                                    especializados
                                </li>
                                <li>
                                    <i class="fas fa-check"></i> Almuerzo de networking
                                </li>
                                <li>
                                    <i class="fas fa-check"></i> Material físico del
                                    congreso
                                </li>
                                <li>
                                    <i class="fas fa-check"></i> Certificado premium
                                </li>
                            </ul>
                            <a href="#" class="btn btn-primary">Inscribirse</a>
                        </div>

                        <div class="card pricing-card">
                            <div class="card-header">
                                <h3>Corporativo</h3>
                                <div class="price">S/ 2,500</div>
                                <div class="price-note">5 personas</div>
                            </div>
                            <ul class="benefits-list">
                                <li>
                                    <i class="fas fa-check"></i> Todo lo del paquete
                                    Profesional
                                </li>
                                <li>
                                    <i class="fas fa-check"></i> Logo en material
                                    del evento
                                </li>
                                <li>
                                    <i class="fas fa-check"></i> Stand promocional
                                </li>
                                <li>
                                    <i class="fas fa-check"></i> Sesión de presentación
                                    empresarial
                                </li>
                                <li>
                                    <i class="fas fa-check"></i> Acceso VIP a áreas
                                    exclusivas
                                </li>
                            </ul>
                            <a href="#" class="btn btn-secondary">Contactar</a>
                        </div>
                    </div>

                    <div class="info-section">
                        <h2>Proceso de Inscripción</h2>
                        <div class="steps-grid">
                            <div class="step-card">
                                <div class="step-number">1</div>
                                <h3>Regístrate</h3>
                                <p>
                                    Ut enim ad minim veniam, quis nostrud
                                    exercitation. Completa el formulario con tus
                                    datos personales y selecciona tu categoría.
                                </p>
                            </div>
                            <div class="step-card">
                                <div class="step-number">2</div>
                                <h3>Realiza el pago</h3>
                                <p>
                                    Ullamco laboris nisi ut aliquip ex ea
                                    commodo. Efectúa el pago mediante
                                    transferencia bancaria o tarjeta de
                                    crédito/débito.
                                </p>
                            </div>
                            <div class="step-card">
                                <div class="step-number">3</div>
                                <h3>Confirma tu asistencia</h3>
                                <p>
                                    Duis aute irure dolor in reprehenderit.
                                    Recibirás un correo de confirmación con
                                    todos los detalles del evento.
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="info-section">
                        <h2>Información de Pago</h2>
                        <div class="payment-info">
                            <div class="payment-method">
                                <h3>
                                    <i class="fas fa-university"></i> Transferencia
                                    Bancaria
                                </h3>
                                <p>
                                    <strong>Banco:</strong> Banco de Cr dit del Perú
                                    (BCP)
                                </p>
                                <p>
                                    <strong>Cuenta Corriente:</strong> 1234-5678-9012-3456
                                </p>
                                <p>
                                    <strong>CCI:</strong> 002-123-456789012345678
                                </p>
                                <p><strong>Titular:</strong> CONAIGEO 2026</p>
                            </div>
                            <div class="payment-method">
                                <h3>
                                    <i class="fas fa-credit-card"></i> Pago en Línea
                                </h3>
                                <p>
                                    Excepteur sint occaecat cupidatat non
                                    proident. Acepta todas las tarjetas de
                                    crédito y débito.
                                </p>
                                <p>
                                    Sunt in culpa qui officia deserunt mollit
                                    anim id est laborum.
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="info-section">
                        <h2>Preguntas Frecuentes</h2>
                        <div class="faq-list">
                            <div class="faq-item">
                                <h3>¿El precio incluye alimentos?</h3>
                                <p>
                                    Sed ut perspiciatis unde omnis iste natus
                                    error sit voluptatem. Los coffee breaks
                                    están incluidos en todos los paquetes. El
                                    almuerzo está incluido solo en los paquetes
                                    Profesional y Corporativo.
                                </p>
                            </div>
                            <div class="faq-item">
                                <h3>¿Puedo cancelar mi inscripción?</h3>
                                <p>
                                    Totam rem aperiam eaque ipsa quae ab illo
                                    inventore veritatis. Las cancelaciones con
                                    más de 30 días de anticipación tienen
                                    reembolso del 80%. Quasi architecto beatae
                                    vitae dicta sunt explicabo.
                                </p>
                            </div>
                            <div class="faq-item">
                                <h3>¿Ofrecen descuentos grupales?</h3>
                                <p>
                                    Nemo enim ipsam voluptatem quia voluptas sit
                                    aspernatur. Sí, ofrecemos descuentos a
                                    partir de 3 inscripciones. Contacta con
                                    nosotros para más información.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</Layout>

<style>
    .page-header {
        background: var(--gradient-hero);
        color: var(--color-white);
        padding: 8rem 0 4rem;
        text-align: center;
        margin-top: 80px;
    }

    .page-header h1 {
        color: var(--color-white);
        margin-bottom: 1rem;
    }

    .page-header p {
        font-size: 1.25rem;
        color: rgba(255, 255, 255, 0.9);
        max-width: 600px;
        margin: 0 auto;
    }

    .content-wrapper {
        max-width: 1200px;
        margin: 3rem auto;
    }

    .registration-info h2 {
        color: var(--color-primary);
        margin-top: 3rem;
        margin-bottom: 1.5rem;
    }

    .registration-info h2:first-of-type {
        margin-top: 0;
    }

    .pricing-cards {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
        margin: 3rem 0;
    }

    .pricing-card {
        position: relative;
        text-align: center;
        transition: all var(--transition-normal);
    }

    .pricing-card:hover {
        transform: translateY(-10px);
        box-shadow: var(--shadow-xl);
    }

    .pricing-card.featured {
        border: 3px solid var(--color-primary);
        transform: scale(1.05);
    }

    .featured-badge {
        position: absolute;
        top: -15px;
        left: 50%;
        transform: translateX(-50%);
        background: var(--gradient-primary);
        color: var(--color-white);
        padding: 0.5rem 1.5rem;
        border-radius: var(--radius-full);
        font-weight: 700;
        font-size: 0.875rem;
        box-shadow: var(--shadow-md);
    }

    .card-header {
        padding: 2rem;
        background: var(--gradient-primary);
        color: var(--color-white);
        border-radius: var(--radius-lg) var(--radius-lg) 0 0;
    }

    .card-header h3 {
        color: var(--color-white);
        margin-bottom: 1rem;
        font-size: 1.5rem;
    }

    .price {
        font-size: 2.5rem;
        font-weight: 900;
        font-family: var(--font-heading);
    }

    .price-note {
        font-size: 0.875rem;
        opacity: 0.9;
        margin-top: 0.5rem;
    }

    .benefits-list {
        list-style: none;
        padding: 2rem;
        text-align: left;
    }

    .benefits-list li {
        display: flex;
        align-items: start;
        gap: 0.75rem;
        margin-bottom: 1rem;
        font-size: 0.95rem;
    }

    .benefits-list i {
        color: var(--color-primary);
        margin-top: 0.25rem;
        flex-shrink: 0;
    }

    .pricing-card .btn {
        margin: 0 2rem 2rem 2rem;
        width: calc(100% - 4rem);
    }

    .steps-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 2rem;
        margin: 2rem 0;
    }

    .step-card {
        text-align: center;
        padding: 2rem;
        border: 2px solid var(--color-light);
        border-radius: var(--radius-lg);
        transition: all var(--transition-normal);
    }

    .step-card:hover {
        border-color: var(--color-primary);
        box-shadow: var(--shadow-md);
    }

    .step-number {
        width: 60px;
        height: 60px;
        margin: 0 auto 1rem;
        background: var(--gradient-primary);
        color: var(--color-white);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.75rem;
        font-weight: 900;
        font-family: var(--font-heading);
    }

    .step-card h3 {
        color: var(--color-dark);
        margin-bottom: 1rem;
    }

    .info-section {
        margin: 4rem 0;
    }

    .payment-info {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
        margin-top: 2rem;
    }

    .payment-method {
        padding: 2rem;
        background: var(--color-light);
        border-radius: var(--radius-lg);
        border-left: 4px solid var(--color-primary);
    }

    .payment-method h3 {
        color: var(--color-primary);
        margin-bottom: 1.5rem;
        display: flex;
        align-items: center;
        gap: 0.75rem;
    }

    .payment-method p {
        margin-bottom: 0.75rem;
    }

    .faq-list {
        margin-top: 2rem;
    }

    .faq-item {
        padding: 2rem;
        background: var(--color-white);
        border-radius: var(--radius-lg);
        box-shadow: var(--shadow-md);
        margin-bottom: 1.5rem;
        border-left: 4px solid var(--color-primary);
    }

    .faq-item h3 {
        color: var(--color-dark);
        margin-bottom: 1rem;
    }

    .faq-item p {
        line-height: 1.8;
        color: var(--color-text-light);
    }

    @media (max-width: 768px) {
        .page-header {
            padding: 6rem 0 3rem;
        }

        .pricing-cards {
            grid-template-columns: 1fr;
        }

        .pricing-card.featured {
            transform: scale(1);
        }
    }
</style>
