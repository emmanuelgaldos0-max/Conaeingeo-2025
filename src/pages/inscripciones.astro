---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Inscripciones - CONAEINGEO 2026">
    <!-- Page Header -->
    <section class="page-header">
        <div class="container">
            <h1>Inscripciones</h1>
            <p>Únete al evento más importante de minería del sur del Perú</p>
        </div>
    </section>

    <!-- Registration Content -->
    <section class="section">
        <div class="container">
            <div class="content-wrapper">
                <div class="registration-info">
                    <h2>Inversión y Beneficios</h2>
                    <p>
                        Participa en el XV CONAEINGEO – Arequipa 2026 y forma
                        parte de uno de los encuentros académicos más importantes
                        para estudiantes y profesionales de Ingeniería Geológica.
                        La inscripción te permitirá acceder a actividades
                        académicas, espacios de integración y experiencias de
                        aprendizaje vinculadas a las geociencias.
                    </p>

                    <div class="pricing-cards">
                        <div class="card pricing-card pass-card costo-card">
                            <div class="pass-visual">
                                <img src="/entradas/4.png" alt="Pass por confirmar" />
                            </div>
                            <div class="card-header">
                                
                                <div class="price">Próximamente</div>
                                <div class="price-note">Precio estudiante por confirmar</div>
                            </div>
                            <ul class="benefits-list">
                                <li>
                                    <i class="fas fa-check"></i> Acceso oficial al XV CONAEINGEO
                                </li>
                                <li>
                                    <i class="fas fa-check"></i> Certificado de participación
                                </li>
                                <li>
                                    <i class="fas fa-check"></i> Acceso a la Feria Tecnológica
                                </li>
                                <li>
                                    <i class="fas fa-check"></i> Beneficios adicionales según la pieza promocional oficial
                                </li>
                            </ul>
                            <a href="#" class="btn btn-secondary">Inscribirse</a>
                        </div>

                        <div class="card pricing-card pass-card chachani-card">
                            <div class="pass-visual">
                                <img src="/entradas/Chachani.png" alt="Descubre Pass Chachani" />
                            </div>
                            <div class="card-header">
                                
                                <div class="price">S/ 140</div>
                                <div class="price-note">Tarifa estudiante</div>
                            </div>
                            <ul class="benefits-list">
                                <li>
                                    <i class="fas fa-check"></i> Acceso oficial al XV CONAEINGEO
                                </li>
                                <li>
                                    <i class="fas fa-check"></i> Certificado de participación
                                </li>
                                <li>
                                    <i class="fas fa-check"></i> Explorer Kit XV CONAEINGEO
                                </li>
                                <li>
                                    <i class="fas fa-check"></i> Acceso a la Feria Tecnológica & Expo Empresarial
                                </li>
                                <li>
                                    <i class="fas fa-check"></i> 50% de descuento en cursos electivos especializados
                                </li>
                            </ul>
                            <a href="#" class="btn btn-secondary">Inscribirse</a>
                        </div>

                        <!--
                        <div class="card pricing-card pass-card featured misti-card">
                            <div class="featured-badge">Recomendado</div>
                            <div class="pass-visual">
