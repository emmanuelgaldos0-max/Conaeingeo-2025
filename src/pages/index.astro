---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Inicio - CONAIGEO 2026 | Congreso de Minería Arequipa">
	<!-- Hero Section -->
	<section class="hero" id="hero">
		<div class="hero-overlay"></div>
		<div class="hero-content">
			<div class="container">
				<div class="hero-badge fade-in-up">
					<i class="fas fa-calendar-alt"></i>
					<span>15-18 Septiembre 2026</span>
				</div>
				<h1 class="hero-title fade-in-up">
					Minería Responsable,<br />
					<span class="gradient-text">Progreso para Arequipa</span>
				</h1>
				<p class="hero-subtitle fade-in-up">
					Del 15 al 18 de Septiembre 2026
				</p>
				<div class="hero-location fade-in-up">
					<i class="fas fa-map-marker-alt"></i>
					<span
						>Sede: Universidad Nacional de San Agustín | ¡Arequipa
						te espera!</span
					>
				</div>
				<div class="hero-cta fade-in-up">
					<a href="/inscripciones" class="btn btn-primary btn-large">
						<i class="fas fa-ticket-alt"></i>
						Inscríbete Ahora
					</a>
					<a href="#acerca" class="btn btn-secondary btn-large">
						<i class="fas fa-info-circle"></i>
						Conoce Más
					</a>
				</div>
				<div class="scroll-indicator">
					<i class="fas fa-chevron-down"></i>
				</div>
			</div>
		</div>
	</section>

	<!-- About Section -->
	<section class="section about" id="acerca">
		<div class="container">
			<div class="section-title">
				<h2>Acerca del Congreso</h2>
				<p>Lorem ipsum dolor sit amet consectetur adipiscing elit</p>
			</div>
			<div class="about-grid">
				<div class="about-content">
					<h3>CONAIGEO 2026</h3>
					<p>
						El Congreso Nacional de Estudiantes de Ingeniería Geológica (CONAEINGEO) 
						es el evento académico estudiantil más importante del Perú en el ámbito de las geociencias. 
						Se desarrolla anualmente y congrega a estudiantes, docentes, investigadores, profesionales 
						y representantes del sector productivo de todo el país, consolidándose como un espacio 
						de referencia para la actualización científica, el intercambio académico y la integración nacional.
					</p>
					<p>
						El XV CONAEINGEO – Arequipa 2026 se presenta como un encuentro académico 
						de alto nivel que articula ciencia, innovación y experiencia de campo, 
						promoviendo la vinculación con el sector profesional. 
						A través de conferencias magistrales, cursos especializados, 
						talleres y salidas de campo, el congreso reafirma su carácter formativo, 
						integrador y multidisciplinario, orientado al fortalecimiento de la formación 
						académica y profesional de los futuros ingenieros geólogos del Perú.
					</p>
					<div class="about-features">
						<div class="feature-item">
							<div class="feature-icon">
								<i class="fas fa-users"></i>
							</div>
							<div class="feature-text">
								<h4>+500 Participantes</h4>
								<p>Profesionales de la región sur</p>
							</div>
						</div>
						<div class="feature-item">
							<div class="feature-icon">
								<i class="fas fa-chalkboard-teacher"></i>
							</div>
							<div class="feature-text">
								<h4>30+ Ponentes</h4>
								<p>Lorem ipsum dolor</p>
							</div>
						</div>
						<div class="feature-item">
							<div class="feature-icon">
								<i class="fas fa-calendar-check"></i>
							</div>
							<div class="feature-text">
								<h4>4 Días</h4>
								<p>Lorem ipsum dolor</p>
							</div>
						</div>
						<div class="feature-item">
							<div class="feature-icon">
								<i class="fas fa-award"></i>
							</div>
							<div class="feature-text">
								<h4>Certificación</h4>
								<p>Lorem ipsum dolor</p>
							</div>
						</div>
					</div>
				</div>
				<div class="about-image">
					<div class="image-card">
						<i class="fas fa-mountain icon-large"></i>
						<h4>Contexto Minero</h4>
						<p>
							Talleres prácticos y presentaciones de tecnologías
							emergentes
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Speakers Section -->
	<section class="section speakers" id="ponentes">
		<div class="container">
			<div class="section-title">
				<h2>Ponentes Destacados</h2>
				<p>Lorem ipsum dolor sit amet consectetur</p>
			</div>
			<div class="speakers-grid">
				<div class="speaker-card">
					<div class="speaker-image">
						<img
							src="/speakers/speaker1.png"
							alt="Dr. Carlos Mendoza"
						/>
						<div class="speaker-overlay">
							<div class="social-links">
								<a href="#"><i class="fab fa-linkedin"></i></a>
								<a href="#"><i class="fas fa-envelope"></i></a>
							</div>
						</div>
					</div>
					<div class="speaker-info">
						<h3>Dr. Carlos Mendoza</h3>
						<p class="speaker-title">Ingeniero de Minas Senior</p>
						<p class="speaker-bio">
							Lorem ipsum dolor sit amet consectetur adipiscing
							elit sed do eiusmod tempor incididunt ut labore et
							dolore magna aliqua.
						</p>
						<div class="speaker-topic">
							<i class="fas fa-microphone"></i>
							<span>Innovación en Extracción Minera</span>
						</div>
					</div>
				</div>

				<div class="speaker-card">
					<div class="speaker-image">
						<img
							src="/speakers/speaker2.png"
							alt="Dra. María Torres"
						/>
						<div class="speaker-overlay">
							<div class="social-links">
								<a href="#"><i class="fab fa-linkedin"></i></a>
								<a href="#"><i class="fas fa-envelope"></i></a>
							</div>
						</div>
					</div>
					<div class="speaker-info">
						<h3>Dra. María Torres</h3>
						<p class="speaker-title">Geóloga Especialista</p>
						<p class="speaker-bio">
							Lorem ipsum dolor sit amet consectetur adipiscing
							elit sed do eiusmod tempor incididunt ut labore et
							dolore magna aliqua.
						</p>
						<div class="speaker-topic">
							<i class="fas fa-microphone"></i>
							<span>Exploración Mineral Sostenible</span>
						</div>
					</div>
				</div>

				<div class="speaker-card">
					<div class="speaker-image">
						<img
							src="/speakers/speaker3.png"
							alt="Dr. Roberto Silva"
						/>
						<div class="speaker-overlay">
							<div class="social-links">
								<a href="#"><i class="fab fa-linkedin"></i></a>
								<a href="#"><i class="fas fa-envelope"></i></a>
							</div>
						</div>
					</div>
					<div class="speaker-info">
						<h3>Dr. Roberto Silva</h3>
						<p class="speaker-title">Profesor de Metalurgia</p>
						<p class="speaker-bio">
							Lorem ipsum dolor sit amet consectetur adipiscing
							elit sed do eiusmod tempor incididunt ut labore et
							dolore magna aliqua.
						</p>
						<div class="speaker-topic">
							<i class="fas fa-microphone"></i>
							<span>Metalurgia del Futuro</span>
						</div>
					</div>
				</div>
			</div>
			<div class="speakers-cta">
				<a href="/actividades" class="btn btn-primary">
					Ver Programa Completo
					<i class="fas fa-arrow-right"></i>
				</a>
			</div>
		</div>
	</section>

	<!-- Schedule Preview -->
	<section class="section schedule-preview">
		<div class="container">
			<div class="section-title">
				<h2>Calendario de Actividades</h2>
				<p>Lorem ipsum dolor sit amet consectetur</p>
			</div>
			<div class="schedule-timeline">
				<div class="timeline-item">
					<div class="timeline-date">
						<span class="day">15</span>
						<span class="month">SEP</span>
					</div>
					<div class="timeline-content">
						<h3>Día 1: Inauguración</h3>
						<p>
							Ceremonia de apertura, conferencias magistrales y
							sesión plenaria
						</p>
						<ul>
							<li>Palabras de bienvenida autoridades UNSA</li>
							<li>
								Conferencia: Estado actual de la minería en Perú
							</li>
							<li>
								Panel: Desafíos de la industria minera moderna
							</li>
						</ul>
					</div>
				</div>

				<div class="timeline-item">
					<div class="timeline-date">
						<span class="day">16</span>
						<span class="month">SEP</span>
					</div>
					<div class="timeline-content">
						<h3>Día 2: Innovación Tecnológica</h3>
						<p>Lorem ipsum dolor sit amet consectetur</p>
						<ul>
							<li>
								Taller: Automatización en minería subterránea
							</li>
							<li>
								Conferencia: Inteligencia artificial en
								exploración
							</li>
							<li>
								Showcase: Nuevas tecnologías de procesamiento
							</li>
						</ul>
					</div>
				</div>

				<div class="timeline-item">
					<div class="timeline-date">
						<span class="day">17</span>
						<span class="month">SEP</span>
					</div>
					<div class="timeline-content">
						<h3>Día 3: Sostenibilidad</h3>
						<p>
							Minería responsable y gestión ambiental sostenible
						</p>
						<ul>
							<li>Panel: Minería verde y economía circular</li>
							<li>Taller: Gestión de recursos hídricos</li>
							<li>
								Conferencia: Relaciones comunitarias exitosas
							</li>
						</ul>
					</div>
				</div>

				<div class="timeline-item">
					<div class="timeline-date">
						<span class="day">18</span>
						<span class="month">SEP</span>
					</div>
					<div class="timeline-content">
						<h3>Día 4: Clausura</h3>
						<p>Lorem ipsum dolor sit amet consectetur</p>
						<ul>
							<li>Presentación de casos de éxito</li>
							<li>Sesión de networking empresarial</li>
							<li>
								Ceremonia de clausura y entrega de certificados
							</li>
						</ul>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Organizers Section -->
	<section class="section organizers" id="organizadores">
		<div class="container">
			<div class="section-title">
				<h2>Organizadores</h2>
				<p>Lorem ipsum dolor sit amet</p>
			</div>
			<div class="organizers-grid">
				<div class="org-card">
					<div class="org-icon">
						<i class="fas fa-university"></i>
					</div>
					<h3>UNSA</h3>
					<p>Universidad Nacional de San Agustín de Arequipa</p>
				</div>
				<div class="org-card">
					<div class="org-icon">
						<i class="fas fa-gem"></i>
					</div>
					<h3>Escuela de Ingeniería de Minas</h3>
					<p>Facultad de Geología, Geofísica y Minas</p>
				</div>
				<div class="org-card">
					<div class="org-icon">
						<i class="fas fa-handshake"></i>
					</div>
					<h3>Comité Organizador CONAIGEO</h3>
					<p>Estudiantes y profesionales del sector minero</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Sponsors Section -->
	<section class="section sponsors">
		<div class="container">
			<div class="section-title">
				<h2>Patrocinadores</h2>
				<p>Lorem ipsum dolor sit amet consectetur</p>
			</div>
			<div class="sponsors-tier">
				<h3>Patrocinadores Oro</h3>
				<div class="sponsors-logos gold">
					<div class="sponsor-placeholder">
						<i class="fas fa-industry"></i>
						<p>Empresa Minera 1</p>
					</div>
					<div class="sponsor-placeholder">
						<i class="fas fa-industry"></i>
						<p>Empresa Minera 2</p>
					</div>
				</div>
			</div>
			<div class="sponsors-tier">
				<h3>Patrocinadores Plata</h3>
				<div class="sponsors-logos silver">
					<div class="sponsor-placeholder">
						<i class="fas fa-tools"></i>
						<p>Proveedor 1</p>
					</div>
					<div class="sponsor-placeholder">
						<i class="fas fa-tools"></i>
						<p>Proveedor 2</p>
					</div>
					<div class="sponsor-placeholder">
						<i class="fas fa-tools"></i>
						<p>Proveedor 3</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Location Section -->
	<section class="section location" id="ubicacion">
		<div class="container">
			<div class="section-title">
				<h2>Ubicación</h2>
				<p>Universidad Nacional de San Agustín, Arequipa</p>
			</div>
			<div class="location-grid">
				<div class="location-info">
					<div class="info-item">
						<i class="fas fa-map-marker-alt"></i>
						<div>
							<h4>Dirección</h4>
							<p>
								Av. Independencia s/n, Cercado de Arequipa<br
								/>Arequipa 04001, Perú
							</p>
						</div>
					</div>
					<div class="info-item">
						<i class="fas fa-phone"></i>
						<div>
							<h4>Contacto</h4>
							<p>+51 54 123456<br />contacto@conaigeo2026.com</p>
						</div>
					</div>
					<div class="info-item">
						<i class="fas fa-hotel"></i>
						<div>
							<h4>Alojamiento</h4>
							<p>
								Hoteles recomendados cerca de la sede con
								tarifas especiales para participantes del
								congreso
							</p>
						</div>
					</div>
					<div class="info-item">
						<i class="fas fa-car"></i>
						<div>
							<h4>Cómo Llegar</h4>
							<p>
								Desde el aeropuerto: 20 minutos en taxi<br
								/>Transporte público y shuttles disponibles
							</p>
						</div>
					</div>
				</div>
				<div class="location-map">
					<div class="map-placeholder">
						<i class="fas fa-map"></i>
						<p>Google Maps</p>
						<small>Ubicación: UNSA, Arequipa</small>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Final CTA Section -->
	<section class="section cta-final">
		<div class="container">
			<div class="cta-content">
				<h2>¿Listo para ser parte de CONAIGEO 2026?</h2>
				<p>
					Asegura tu lugar en el evento minero más importante de la
					región sur.<br />
					¡Las inscripciones anticipadas tienen descuentos especiales!
				</p>
				<div class="cta-buttons">
					<a href="/inscripciones" class="btn btn-primary btn-large">
						<i class="fas fa-ticket-alt"></i>
						Inscríbete Ahora
					</a>
					<a href="/contacto" class="btn btn-secondary btn-large">
						<i class="fas fa-envelope"></i>
						Contáctanos
					</a>
				</div>
				<div class="cta-social">
					<p>Síguenos en redes sociales:</p>
					<div class="social-icons">
						<a href="#"><i class="fab fa-facebook"></i></a>
						<a href="#"><i class="fab fa-instagram"></i></a>
						<a href="#"><i class="fab fa-twitter"></i></a>
						<a href="#"><i class="fab fa-linkedin"></i></a>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>

<style>
	/* Hero Section */
	.hero {
		position: relative;
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		background:
			var(--gradient-hero),
			url("/hero-bg.png") center/cover no-repeat;
		color: var(--color-white);
		overflow: hidden;
	}

	.hero-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: var(--gradient-overlay);
	}

	.hero-content {
		position: relative;
		z-index: 1;
		text-align: center;
		padding: 8rem 0 4rem;
	}

	.hero-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		background: rgba(255, 255, 255, 0.1);
		backdrop-filter: blur(10px);
		padding: 0.75rem 1.5rem;
		border-radius: var(--radius-full);
		border: 1px solid rgba(255, 255, 255, 0.2);
		margin-bottom: 2rem;
		font-weight: 600;
	}

	.hero-title {
		font-size: clamp(2.5rem, 6vw, 5rem);
		font-weight: 900;
		margin-bottom: 1.5rem;
		line-height: 1.1;
		color: var(--color-white);
	}

	.gradient-text {
		background: var(--gradient-primary);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.hero-subtitle {
		font-size: clamp(1.25rem, 2vw, 1.75rem);
		margin-bottom: 2rem;
		color: rgba(255, 255, 255, 0.9);
	}

	.hero-location {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		font-size: 1.125rem;
		margin-bottom: 3rem;
		color: var(--color-primary-light);
	}

	.hero-cta {
		display: flex;
		gap: 1.5rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	.btn-large {
		padding: 1.25rem 3rem;
		font-size: 1.25rem;
	}

	.btn-large i {
		margin-right: 0.5rem;
	}

	.scroll-indicator {
		position: absolute;
		bottom: 2rem;
		left: 50%;
		transform: translateX(-50%);
		animation: float 2s ease-in-out infinite;
		font-size: 2rem;
		opacity: 0.7;
	}

	/* About Section */
	.about {
		background: var(--color-white);
	}

	.about-grid {
		display: grid;
		grid-template-columns: 1.5fr 1fr;
		gap: var(--spacing-lg);
		align-items: center;
	}

	.about-content h3 {
		color: var(--color-primary);
		margin-bottom: 1.5rem;
	}

	.about-content p {
		margin-bottom: 1.5rem;
	}

	.about-features {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem;
		margin-top: 2rem;
	}

	.feature-item {
		display: flex;
		gap: 1rem;
		align-items: flex-start;
	}

	.feature-icon {
		width: 60px;
		height: 60px;
		border-radius: var(--radius-md);
		background: var(--gradient-primary);
		display: flex;
		align-items: center;
		justify-content: center;
		flex-shrink: 0;
		color: var(--color-white);
		font-size: 1.5rem;
	}

	.feature-text h4 {
		font-size: 1.125rem;
		margin-bottom: 0.25rem;
		color: var(--color-dark);
	}

	.feature-text p {
		font-size: 0.95rem;
		margin: 0;
	}

	.about-image {
		position: relative;
	}

	.image-card {
		background: var(--gradient-primary);
		padding: var(--spacing-lg);
		border-radius: var(--radius-lg);
		text-align: center;
		color: var(--color-white);
		box-shadow: var(--shadow-xl);
	}

	.icon-large {
		font-size: 5rem;
		margin-bottom: 1.5rem;
		opacity: 0.9;
	}

	.image-card h4 {
		color: var(--color-white);
		font-size: 1.75rem;
		margin-bottom: 1rem;
	}

	.image-card p {
		color: rgba(255, 255, 255, 0.95);
		font-size: 1rem;
	}

	/* Speakers Section */
	.speakers {
		background: var(--color-light);
	}

	.speakers-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
		gap: 2.5rem;
		margin-bottom: 3rem;
	}

	.speaker-card {
		background: var(--color-white);
		border-radius: var(--radius-lg);
		overflow: hidden;
		box-shadow: var(--shadow-md);
		transition: all var(--transition-normal);
	}

	.speaker-card:hover {
		transform: translateY(-10px);
		box-shadow: var(--shadow-xl);
	}

	.speaker-image {
		position: relative;
		overflow: hidden;
		aspect-ratio: 1;
	}

	.speaker-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform var(--transition-slow);
	}

	.speaker-card:hover .speaker-image img {
		transform: scale(1.1);
	}

	.speaker-overlay {
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background: rgba(15, 23, 42, 0.85);
		display: flex;
		align-items: center;
		justify-content: center;
		opacity: 0;
		transition: opacity var(--transition-normal);
	}

	.speaker-card:hover .speaker-overlay {
		opacity: 1;
	}

	.social-links {
		display: flex;
		gap: 1rem;
	}

	.social-links a {
		width: 50px;
		height: 50px;
		border-radius: 50%;
		background: var(--color-white);
		display: flex;
