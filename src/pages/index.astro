---
import Layout from "../layouts/Layout.astro";
import { activityDays } from "../data/activities";
---

<Layout title="Inicio - CONAEINGEO 2026 | Congreso de Ingeniería Geológica Arequipa">
	<!-- Hero Section -->
	<section class="hero" id="hero">
		<div class="hero-slides">
			<div class="hero-slide" style="background-image: url('/portada/1.jpg')"></div>
			<div class="hero-slide" style="background-image: url('/portada/2.png')"></div>
			<div class="hero-slide" style="background-image: url('/portada/3.png')"></div>
		</div>
		<div class="hero-overlay"></div>
		<div class="hero-content">
			<div class="container">
				
				<div class="hero-text-backdrop">
			<h1 class="hero-title fade-in-up">
					XV CONAEINGEO AREQUIPA 2026,<br />
					<span class="gradient-text">CONSTRUYENDO EL FUTURO DE LAS GEOCIENCIAS EN EL PERÚ</span>
				</h1>
				<p class="hero-subtitle fade-in-up">
					El principal encuentro académico de las geociencias en el Perú
				</p>
				</div>
				<div class="hero-date fade-in-up">
					<div class="hero-date-col">
						<span class="date-num">02</span>
						<span class="date-label">Agosto</span>
					</div>
					<div class="hero-date-sep">—</div>
					<div class="hero-date-col">
						<span class="date-num">08</span>
						<span class="date-label">Agosto</span>
					</div>
					<div class="hero-date-sep">·</div>
					<div class="hero-date-col">
						<span class="date-num">2026</span>
						<span class="date-label">Arequipa, Perú</span>
					</div>
				</div>
				<div class="hero-cta fade-in-up">
					<a href="/inscripciones" class="btn btn-primary btn-large">
						<i class="fas fa-ticket-alt"></i>
						Inscríbete Ahora
					</a>
					<a href="#acerca" class="btn btn-secondary btn-large">
						<i class="fas fa-info-circle"></i>
						Conoce Más
					</a>
				</div>
				<div class="countdown-wrapper fade-in-up">
					<div class="countdown" id="countdown">
						<div class="countdown-item">
							<span id="countdown-days">--</span>
							<small>Días</small>
						</div>
						<div class="countdown-item">
							<span id="countdown-hours">--</span>
							<small>Horas</small>
						</div>
						<div class="countdown-item">
							<span id="countdown-minutes">--</span>
							<small>Minutos</small>
						</div>
						<div class="countdown-item">
							<span id="countdown-seconds">--</span>
							<small>Segundos</small>
						</div>
					</div>
				</div>
				<div class="scroll-indicator">
					<i class="fas fa-chevron-down"></i>
				</div>
			</div>
		</div>
	</section>

	<!-- About Section -->
	<section class="section about" id="acerca">
		<div class="container">
			<div class="section-title">
				<h2>Acerca del Congreso</h2>
				<p>Un encuentro académico que integra formación, investigación, innovación y proyección profesional en geociencias.</p>
			</div>
			<div class="about-grid">
				<div class="about-content">
					<h3>XV CONAEINGEO – Arequipa 2026</h3>
					<p>
						El Congreso Nacional de Estudiantes de Ingeniería Geológica (CONAEINGEO) 
						es el evento académico estudiantil más importante del Perú en el ámbito de las geociencias. 
						Se desarrolla anualmente y congrega a estudiantes, docentes, investigadores, profesionales 
						y representantes del sector productivo de todo el país, consolidándose como un espacio 
						de referencia para la actualización científica, el intercambio académico y la integración nacional.
					</p>
					<p>
						El XV CONAEINGEO – Arequipa 2026 se presenta como un encuentro académico 
						de alto nivel que articula ciencia, innovación y experiencia de campo, 
						promoviendo la vinculación con el sector profesional. 
						A través de conferencias magistrales, cursos especializados, 
						talleres y salidas de campo, el congreso reafirma su carácter formativo, 
						integrador y multidisciplinario, orientado al fortalecimiento de la formación 
						académica y profesional de los futuros ingenieros geólogos del Perú.
					</p>
					<div class="about-features">
						<div class="feature-item">
							<div class="feature-icon">
								<i class="fas fa-users"></i>
							</div>
							<div class="feature-text">
								<h4>+500 Participantes</h4>
								<p>Estudiantes, egresados y profesionales de todo el país</p>
							</div>
						</div>
						<div class="feature-item">
							<div class="feature-icon">
								<i class="fas fa-chalkboard-teacher"></i>
							</div>
							<div class="feature-text">
								<h4>+30 Ponentes</h4>
								<p>Nacionales e Internacionales</p>
							</div>
						</div>
						<div class="feature-item">
							<div class="feature-icon">
								<i class="fas fa-calendar-check"></i>
							</div>
							<div class="feature-text">
								<h4>7 Días</h4>
								<p>Conferencias, Workshop, Concursos, Visitas Tecnicas y Salidas a Campo</p>
							</div>
						</div>
						<div class="feature-item">
							<div class="feature-icon">
								<i class="fas fa-award"></i>
							</div>
							<div class="feature-text">
								<h4>Certificación</h4>

							</div>
						</div>
					</div>
				</div>
				<div class="about-image">
				    <div class="image-card">
				        <img src="/portada/CONTEXTO MINERO.png" alt="Contexto Minero" class="contexto-img" />
				    </div>
				</div>
			</div>
		</div>
	</section>

