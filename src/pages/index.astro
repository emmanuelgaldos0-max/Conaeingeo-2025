	<!-- Schedule Preview -->
	<section class="section schedule-preview">
		<div class="container">
			<div class="section-title">
				<h2>Calendario de Actividades</h2>

			</div>
			<div class="schedule-timeline">
				{activityDays.map((day) => (
					<div class="timeline-item">
						<div class="timeline-date">
							<span class="day">{day.date.slice(0, 2)}</span>
							<span class="month">{day.monthShort}</span>
						</div>
						<div class="timeline-content">
							<h3>{`Día ${day.dayNumber}: ${day.title}`}</h3>
							<p>{day.summary}</p>
							<ul>
								{day.bullets.map((bullet) => <li>{bullet}</li>)}
							</ul>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>

	<!-- Organizers Section -->
	<section class="section organizers" id="organizadores">
		<div class="container">
			<div class="section-title">
				<h2>Organizadores</h2>

			</div>
			<div class="organizers-grid">
				<div class="org-card">
					<div class="org-icon">
						<i class="fas fa-gem"></i>
					</div>
					<h3>Escuela Profesional de Ingeniería Geológica</h3>
					<p>Facultad de Ingeniería Geológica, Geofísica y Minas</p>
				</div>
				<div class="org-card">
					<div class="org-icon">
						<i class="fas fa-handshake"></i>
					</div>
					<h3>Comité Organizador CONAEINGEO</h3>
					<p>Equipo estudiantil responsable de la organización y desarrollo del congreso</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Sponsors Section -->
	<section class="section sponsors">
		<div class="container">
			<div class="section-title">
				<h2>Auspiciadores</h2>

			</div>
			<div class="sponsors-tier">
				<h3>Auspiciadores Oro</h3>
				<div class="sponsors-logos gold">
					<div class="sponsor-placeholder empty-tier">
						<i class="fas fa-award"></i>
						<p>Espacio reservado para auspiciadores oro</p>
					</div>
				</div>
			</div>
			<div class="sponsors-tier">
				<h3>Auspiciadores Plata</h3>
				<div class="sponsors-logos silver">
					<div class="sponsor-logo-card">
						<img src="/auspicios/plata/LOGO GEOMIN NORTH PERU.jpg" alt="GEOMIN NORTH PERU" />
						<p>GEOMIN NORTH PERU</p>
					</div>
					<div class="sponsor-logo-card">
						<img src="/auspicios/plata/LOGO GEOTITAN PRODUCTS.jpg" alt="GEOTITAN PRODUCTS" />
						<p>GEOTITAN PRODUCTS</p>
					</div>
				</div>
			</div>
			<div class="sponsors-tier">
				<h3>Auspiciadores Cobre</h3>
				<div class="sponsors-logos copper">
					<div class="sponsor-logo-card">
						<img src="/auspicios/cobre/LOGO GEOTEKH.jpg" alt="GEOTEKH" />
						<p>GEOTEKH</p>
					</div>
					<div class="sponsor-logo-card">
						<img src="/auspicios/cobre/LOGO MICHIGAN.jpg" alt="MICHIGAN" />
						<p>MICHIGAN</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Location Section -->
	<section class="section location" id="ubicacion">
		<div class="container">
			<div class="section-title">
				<h2>Ubicación</h2>
				<p>Universidad Nacional de San Agustín, Arequipa</p>
			</div>
			<div class="location-grid">
				<div class="location-info">
					<div class="info-item">
						<i class="fas fa-map-marker-alt"></i>
						<div>
							<h4>Dirección</h4>
							<p>
								Av. Independencia s/n, Cercado de Arequipa<br
								/>Arequipa 04001, Perú
							</p>
						</div>
					</div>
					<div class="info-item">
						<i class="fas fa-phone"></i>
						<div>
							<h4>Contacto</h4>
							<p>+51 928525055<br />xvconaeingeoaqp2026@gmail.com</p>
						</div>
					</div>
					<div class="info-item">
						<i class="fas fa-hotel"></i>
						<div>
							<h4>Alojamiento</h4>
							<p>
								Hoteles recomendados cerca de la sede con
								tarifas especiales para participantes del
								congreso
							</p>
						</div>
					</div>
					<div class="info-item">
						<i class="fas fa-car"></i>
						<div>
							<h4>Cómo Llegar</h4>
							<p>
								Desde el aeropuerto: 20 minutos en taxi<br
								/>Transporte público y shuttles disponibles
							</p>
						</div>
					</div>
				</div>
				<div class="location-map">
					<div class="map-embed-wrapper">
						<iframe
							title="Ubicación de UNSA Sociales en Arequipa"
							src="https://www.google.com/maps?q=UNSA%20Sociales%20Arequipa%20Peru&z=16&output=embed"
							loading="lazy"
							referrerpolicy="no-referrer-when-downgrade"
							allowfullscreen
						></iframe>
						<a
							class="map-overlay-link"
							href="https://www.google.com/maps/dir/?api=1&destination=UNSA+Sociales+Arequipa+Peru"
							target="_blank"
							rel="noopener noreferrer"
							aria-label="Abrir cómo llegar en Google Maps"
						>
							<span><i class="fas fa-route"></i> Cómo llegar en Google Maps</span>
						</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Final CTA Section -->
	<section class="section cta-final">
		<div class="container">
			<div class="cta-content">
				<h2>¿Listo para ser parte del XV CONAEINGEO – Arequipa 2026?</h2>
				<p>
					"Asegura tu lugar en el evento de geología más importante del Perú.<br />
					¡Las inscripciones anticipadas tienen descuentos especiales!
				</p>
				<div class="cta-buttons">
					<a href="/inscripciones" class="btn btn-primary btn-large">
						<i class="fas fa-ticket-alt"></i>
						Inscríbete Ahora
					</a>
					<a href="/contacto" class="btn btn-secondary btn-large">
						<i class="fas fa-envelope"></i>
						Contáctanos
					</a>
				</div>
				<div class="cta-social">
					<p>Síguenos en redes sociales:</p>
					<div class="social-icons">
						<a href="#"><i class="fab fa-facebook"></i></a>
						<a href="#"><i class="fab fa-instagram"></i></a>
						<a href="#"><i class="fab fa-linkedin"></i></a>
					</div>
				</div>
			</div>
		</div>
	</section>
</Layout>

<style>
	/* Hero Section */
	.hero {
		position: relative;
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--color-white);
		overflow: hidden;
	}

	.hero-slides {
		position: absolute;
		inset: 0;
		z-index: 0;
	}

	.hero-slide {
		position: absolute;
		inset: 0;
		background-size: cover;
		background-position: center;
		background-repeat: no-repeat;
		opacity: 0;
		animation: slideShow 18s infinite;
	}

	.hero-slide:nth-child(1) { animation-delay: 0s; }
	.hero-slide:nth-child(2) { animation-delay: 6s; }
	.hero-slide:nth-child(3) { animation-delay: 12s; }

	@keyframes slideShow {
		0%   { opacity: 0; }
		5%   { opacity: 1; }
		28%  { opacity: 1; }
		33%  { opacity: 0; }
		100% { opacity: 0; }
	}

	.hero-overlay {
		position: absolute;
		inset: 0;
		z-index: 1;
		background: linear-gradient(
			to bottom,
			rgba(15, 23, 42, 0.65) 0%,
			rgba(15, 23, 42, 0.55) 50%,
			rgba(15, 23, 42, 0.70) 100%
		);
	}

	.hero-content {
		position: relative;
		z-index: 2;
		text-align: center;
		padding: 8rem 0 4rem;
	}

	.hero-text-backdrop {
		background: rgba(10, 20, 50, 0.45);
		backdrop-filter: blur(6px);
		-webkit-backdrop-filter: blur(6px);
		border-radius: 1.25rem;
		padding: 2rem 2.5rem 1.5rem;
		margin: 0 auto 2rem;
		display: block;
		max-width: 860px;
	}

	.hero-date {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1.5rem;
		margin-bottom: 2rem;
	}

	.hero-date-col {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 0.2rem;
	}

	.date-num {
		font-size: clamp(1.75rem, 3vw, 2.5rem);
		font-weight: 900;
		color: var(--color-white);
		line-height: 1;
	}

	.date-label {
		font-size: 0.8rem;
		font-weight: 600;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: rgba(255, 255, 255, 0.65);
	}

	.hero-date-sep {
		font-size: 1.5rem;
		color: rgba(255, 255, 255, 0.35);
		font-weight: 300;
		margin-bottom: 1rem;
	}

	.hero-title {
		font-size: clamp(2.5rem, 6vw, 5rem);
		font-weight: 900;
		margin-bottom: 1.5rem;
		line-height: 1.1;
		color: var(--color-white);
	}

	.gradient-text {
		background: var(--gradient-primary);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}

	.hero-subtitle {
		font-size: clamp(1.25rem, 2vw, 1.75rem);
		margin-bottom: 2rem;
		color: rgba(255, 255, 255, 0.9);
	}

	.hero-location {
		display: inline-flex;
		align-items: center;
		gap: 0.75rem;
		font-size: 1.125rem;
		margin-bottom: 3rem;
		color: var(--color-primary-light);
	}

	.hero-cta {
		display: flex;
		gap: 1.5rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	.btn-large {
		padding: 1.25rem 3rem;
		font-size: 1.25rem;
	}

	.btn-large i {
		margin-right: 0.5rem;
	}

	.countdown-wrapper {
		margin-top: 3rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
	}

	.countdown-label {
		color: rgba(255, 255, 255, 0.92);
		font-size: 1rem;
		font-weight: 600;
		letter-spacing: 0.02em;
	}

	.countdown {
		display: grid;
		grid-template-columns: repeat(4, minmax(110px, 1fr));
		gap: 1rem;
		width: 100%;
		max-width: 650px;
	}

	.countdown-item {
		background: rgba(255, 255, 255, 0.12);
		border: 1px solid rgba(255, 255, 255, 0.2);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border-radius: var(--radius-lg);
		padding: 1.25rem 1rem;
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		box-shadow: var(--shadow-lg);
	}

	.countdown-item span {
		font-family: var(--font-heading);
		font-size: clamp(2rem, 4vw, 3rem);
		font-weight: 900;
		line-height: 1;
		color: var(--color-white);
	}

	.countdown-item small {
		margin-top: 0.5rem;
		font-size: 0.95rem;
		font-weight: 600;
		color: rgba(255, 255, 255, 0.85);
		text-transform: uppercase;
		letter-spacing: 0.08em;
	}

	.scroll-indicator {
		position: absolute;
		bottom: 2rem;
		left: 50%;
		transform: translateX(-50%);
		animation: float 2s ease-in-out infinite;
		font-size: 2rem;
		opacity: 0.7;
	}

	/* About Section */
	.about {
		background: var(--color-white);
	}

	.about-grid {
		display: grid;
		grid-template-columns: 1.5fr 1fr;
		gap: var(--spacing-lg);
		align-items: center;
	}

	.about-content h3 {
		color: var(--color-primary);
		margin-bottom: 1.5rem;
	}

	.about-content p {
		margin-bottom: 1.5rem;
	}

	.about-features {
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 1.5rem;
		margin-top: 2rem;
	}

	.feature-item {
		display: flex;
		gap: 1rem;
		align-items: flex-start;
	}

	.feature-icon {
