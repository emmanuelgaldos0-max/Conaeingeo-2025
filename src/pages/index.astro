---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Inicio - CONAIGEO 2025">
	<div class="hero">
		<h1>Bienvenido a CONAIGEO 2025</h1>
		<p>Congreso</p>
	</div>
</Layout>

<style>
	.hero {
		min-height: 400px;
		display: flex;
		flex-direction: column;
		justify-content: center;
		align-items: center;
		text-align: center;
		padding: 2rem;
		background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
	}

	.hero h1 {
		font-size: 3rem;
		margin-bottom: 1rem;
		color: #2d3748;
	}

	.hero p {
		font-size: 1.5rem;
		color: #4a5568;
	}
</style>
