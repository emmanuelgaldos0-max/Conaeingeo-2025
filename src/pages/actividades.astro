<style>
    .page-header {
        background: var(--gradient-hero);
        color: var(--color-white);
        padding: 8rem 0 4rem;
        text-align: center;
        margin-top: 80px;
    }

    .page-header h1 {
        color: var(--color-white);
        margin-bottom: 1rem;
    }

    .page-header p {
        font-size: 1.25rem;
        color: rgba(255, 255, 255, 0.9);
        max-width: 600px;
        margin: 0 auto;
    }

    .day-schedule {
        margin-bottom: 4rem;
    }

    .day-header {
        display: flex;
        align-items: center;
        gap: 2rem;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 3px solid var(--color-primary);
    }

    .day-badge {
        background: var(--gradient-primary);
        color: var(--color-white);
        padding: 1.5rem 2rem;
        border-radius: var(--radius-lg);
        text-align: center;
        min-width: 180px;
        box-shadow: var(--shadow-lg);
    }

    .day-number {
        display: block;
        font-size: 1.5rem;
        font-weight: 900;
        font-family: var(--font-heading);
    }

    .day-date {
        display: block;
        font-size: 0.95rem;
        opacity: 0.95;
        margin-top: 0.25rem;
    }

    .day-header h2 {
        color: var(--color-dark);
        margin: 0;
    }

    .sessions {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .session-card {
        background: var(--color-white);
        border-radius: var(--radius-lg);
        padding: 2rem;
        box-shadow: var(--shadow-md);
        display: flex;
        gap: 2rem;
        transition: all var(--transition-normal);
        border-left: 4px solid transparent;
    }

    .session-card:hover {
        box-shadow: var(--shadow-lg);
        transform: translateX(5px);
        border-left-color: var(--color-primary);
    }

    .session-card.highlight {
        border-left-color: var(--color-primary);
        background: linear-gradient(
            to right,
            rgba(217, 119, 6, 0.05),
            var(--color-white)
        );
    }

    .session-time {
        min-width: 140px;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: var(--color-primary);
        font-weight: 600;
        font-family: var(--font-heading);
        font-size: 1.125rem;
    }

    .session-time i {
        font-size: 1.25rem;
    }

    .session-content h3 {
        color: var(--color-dark);
        margin-bottom: 0.75rem;
        font-size: 1.25rem;
    }

    .session-content p {
        margin-bottom: 0.75rem;
    }

    .session-content p:last-child {
        margin-bottom: 0;
    }

    .session-location,
    .session-speaker,
    .session-note {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.95rem;
        color: var(--color-text-light);
    }

    .session-location {
        color: var(--color-accent);
        font-weight: 600;
    }

    .session-speaker {
        color: var(--color-secondary);
        font-weight: 600;
    }

    .session-note {
        background: var(--color-light);
        padding: 0.75rem 1rem;
        border-radius: var(--radius-md);
        color: var(--color-primary);
        font-weight: 600;
        margin-top: 0.75rem;
    }

    .download-cta {
        margin-top: 4rem;
        text-align: center;
    }

