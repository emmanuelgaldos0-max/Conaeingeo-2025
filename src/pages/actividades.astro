---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Actividades - CONAEINGEO 2026">
    <!-- Page Header -->
    <section class="page-header">
        <div class="container">
            <h1>Calendario de Actividades</h1>
            <p>Programa completo del congreso - del 02 al 08 de Agosto 2026</p>
        </div>
    </section>

    <!-- FILTERS -->
    <div class="activity-filters">
        <button class="filter-btn active" data-filter="all">Todas</button>
        <button class="filter-btn" data-filter="magistrales">Ponencias Magistrales</button>
        <button class="filter-btn" data-filter="concursos">Concursos</button>
        <button class="filter-btn" data-filter="workshops">Workshops</button>
        <button class="filter-btn" data-filter="tecnica">Visitas Técnicas</button>
        <button class="filter-btn" data-filter="campo">Salidas de campo</button>
    </div>

    <!-- Schedule Content -->
    <section class="section">
        <div class="container">
            <!-- Day 1 -->
            <div class="day-schedule">
                <div class="day-header">
                    <div class="day-badge">
                        <span class="day-number">DÍA 1</span>
                        <span class="day-date">02 de Agosto</span>
                    </div>
                    <h2>Apertura Institucional</h2>
                </div>

                <div class="sessions">
                    <div class="session-card highlight">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>08:00 - 09:30</span>
                        </div>
                        <div class="session-content">
                            <h3>Ceremonia Inaugural</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Auditorio Principal
                            </p>
                            <p>
                                Inicio oficial del XV CONAEINGEO – Arequipa 2026 con la participación de autoridades,
                                comité organizador e invitados especiales.
                            </p>
                        </div>
                    </div>

                    <div class="session-card" data-category="magistrales">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>10:00 - 11:30</span>
                        </div>
                        <div class="session-content">
                            <h3>Mesa Redonda</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Auditorio Principal
                            </p>
                            <p>
                                Espacio de diálogo institucional y académico para compartir perspectivas sobre el congreso,
                                la formación geológica y los retos del sector.
                            </p>
                        </div>
                    </div>

                    <div class="session-card">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>12:00 - 13:00</span>
                        </div>
                        <div class="session-content">
                            <h3>Entrega de Kit</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Hall Principal
                            </p>
                            <p>
                                Entrega de materiales, credenciales e indicaciones generales para los participantes del evento.
                            </p>
                        </div>
                    </div>

                    <div class="session-card">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>16:00 - 18:00</span>
                        </div>
                        <div class="session-content">
                            <h3>Actividad de Bienvenida</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Área de Integración
                            </p>
                            <p>
                                Encuentro de bienvenida para fortalecer el compañerismo, la integración y el inicio de la experiencia del congreso.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Day 2 -->
            <div class="day-schedule">
                <div class="day-header">
                    <div class="day-badge">
                        <span class="day-number">DÍA 2</span>
                        <span class="day-date">03 de Agosto</span>
                    </div>
                    <h2>Jornada Académica Magistral</h2>
                </div>

                <div class="sessions">
                    <div class="session-card highlight" data-category="magistrales">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>09:00 - 11:00</span>
                        </div>
                        <div class="session-content">
                            <h3>Ponencias Magistrales</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Auditorio Principal
                            </p>
                            <p>
                                Exposiciones de especialistas invitados sobre temas de actualidad en geociencias,
                                ingeniería geológica e innovación aplicada.
                            </p>
                        </div>
                    </div>

                    <div class="session-card" data-category="magistrales">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>11:30 - 13:00</span>
                        </div>
                        <div class="session-content">
                            <h3>Foros Académicos</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Sala de Conferencias
                            </p>
                            <p>
                                Espacios de análisis y debate sobre problemáticas, tendencias y oportunidades dentro de la ingeniería geológica.
                            </p>
                        </div>
                    </div>

                    <div class="session-card" data-category="concursos">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>15:00 - 16:30</span>
                        </div>
                        <div class="session-content">
                            <h3>Concurso de Debate</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Aula Magna
                            </p>
                            <p>
                                Dinámica académica orientada al análisis crítico, la argumentación y la participación estudiantil.
                            </p>
                        </div>
                    </div>

                    <div class="session-card">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>17:00 - 18:30</span>
                        </div>
                        <div class="session-content">
                            <h3>Actividad de Integración</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Área Social
                            </p>
                            <p>
                                Espacio destinado a fomentar la convivencia, la interacción y el intercambio entre participantes.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Day 3 -->
            <div class="day-schedule">
                <div class="day-header">
                    <div class="day-badge">
                        <span class="day-number">DÍA 3</span>
                        <span class="day-date">04 de Agosto</span>
                    </div>
                    <h2>Espacios de Análisis y Participación</h2>
                </div>

                <div class="sessions">
                    <div class="session-card highlight" data-category="magistrales">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>09:00 - 11:00</span>
                        </div>
                        <div class="session-content">
                            <h3>Ponencias Temáticas</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Auditorio Principal
                            </p>
                            <p>
                                Jornada de exposiciones enfocadas en temas específicos del congreso y áreas de interés para los asistentes.
                            </p>
                        </div>
                    </div>

                    <div class="session-card" data-category="magistrales">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>11:30 - 13:00</span>
                        </div>
                        <div class="session-content">
                            <h3>Mesa Redonda</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Sala de Conferencias
                            </p>
                            <p>
                                Espacio de discusión abierta para profundizar en temas académicos y profesionales del evento.
                            </p>
                        </div>
                    </div>

                    <div class="session-card" data-category="concursos">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>15:00 - 17:00</span>
                        </div>
                        <div class="session-content">
                            <h3>Concursos Académicos</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Ambientes Académicos
                            </p>
                            <p>
                                Actividades competitivas que promueven creatividad, participación y aplicación de conocimientos.
                            </p>
                        </div>
                    </div>

                    <div class="session-card">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>17:30 - 18:30</span>
                        </div>
                        <div class="session-content">
                            <h3>Actividad de Integración</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Área Social
                            </p>
                            <p>
                                Continuación de los espacios de convivencia entre participantes, organizadores e invitados.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Day 4 -->
            <div class="day-schedule">
                <div class="day-header">
                    <div class="day-badge">
                        <span class="day-number">DÍA 4</span>
                        <span class="day-date">05 de Agosto</span>
                    </div>
                    <h2>Investigación y Formación Aplicada</h2>
                </div>

                <div class="sessions">
                    <div class="session-card highlight" data-category="magistrales">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>09:00 - 11:00</span>
                        </div>
                        <div class="session-content">
                            <h3>Exposición de Investigaciones</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Hall de Exposiciones
                            </p>
                            <p>
                                Presentación de trabajos, estudios y proyectos desarrollados por estudiantes e investigadores.
                            </p>
                        </div>
                    </div>

                    <div class="session-card highlight" data-category="workshops,magistrales">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>11:30 - 13:30</span>
                        </div>
                        <div class="session-content">
                            <h3>Workshop Especializado</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Sala de Talleres
                            </p>
                            <p>
                                Taller práctico orientado a fortalecer capacidades técnicas y aplicar conceptos de manera concreta.
                            </p>
                        </div>
                    </div>

                    <div class="session-card" data-category="concursos">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>15:00 - 17:00</span>
                        </div>
                        <div class="session-content">
                            <h3>Concursos Académicos</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Ambientes Académicos
                            </p>
                            <p>
                                Espacios de evaluación, creatividad y participación estudiantil vinculados al contenido del congreso.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Day 5 -->
            <div class="day-schedule">
                <div class="day-header">
                    <div class="day-badge">
                        <span class="day-number">DÍA 5</span>
                        <span class="day-date">06 de Agosto</span>
                    </div>
                    <h2>Actividades Técnicas</h2>
                </div>

                <div class="sessions">
                    <div class="session-card highlight" data-category="tecnica,campo">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>08:00 - 13:00</span>
                        </div>
                        <div class="session-content">
                            <h3>Visitas Técnicas</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Punto de salida institucional
                            </p>
                            <p>
                                Recorridos guiados para conocer espacios, procesos y escenarios vinculados al ejercicio profesional.
                            </p>
                        </div>
                    </div>

                    <div class="session-card" data-category="campo,tecnica">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>14:30 - 18:00</span>
                        </div>
                        <div class="session-content">
                            <h3>Salidas de Campo</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Zona de práctica
                            </p>
                            <p>
                                Actividades orientadas a la observación, interpretación y análisis directo en terreno.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Day 6 -->
            <div class="day-schedule">
                <div class="day-header">
                    <div class="day-badge">
                        <span class="day-number">DÍA 6</span>
                        <span class="day-date">07 de Agosto</span>
                    </div>
                    <h2>Actividades Técnicas Aplicadas</h2>
                </div>

                <div class="sessions">
                    <div class="session-card highlight" data-category="tecnica,campo">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>08:00 - 13:00</span>
                        </div>
                        <div class="session-content">
                            <h3>Visitas Técnicas Aplicadas</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Punto de salida institucional
                            </p>
                            <p>
                                Continuación de las experiencias técnicas para reforzar la formación aplicada de los participantes.
                            </p>
                        </div>
                    </div>

                    <div class="session-card" data-category="campo,tecnica">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>14:30 - 18:00</span>
                        </div>
                        <div class="session-content">
                            <h3>Salidas de Campo Aplicadas</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Zona de práctica
                            </p>
                            <p>
                                Actividades de observación y análisis con énfasis en la aplicación de conocimientos en campo.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Day 7 -->
            <div class="day-schedule">
                <div class="day-header">
                    <div class="day-badge">
                        <span class="day-number">DÍA 7</span>
                        <span class="day-date">08 de Agosto</span>
                    </div>
                    <h2>Clausura Institucional</h2>
                </div>

                <div class="sessions">
                    <div class="session-card">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>10:00 - 11:30</span>
                        </div>
                        <div class="session-content">
                            <h3>Ceremonia de Clausura</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Auditorio Principal
                            </p>
                            <p>
                                Cierre oficial del congreso con balance general de actividades y mensaje institucional de despedida.
                            </p>
                        </div>
                    </div>

                    <div class="session-card highlight" data-category="concursos">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>11:30 - 12:30</span>
                        </div>
                        <div class="session-content">
                            <h3>Premiación</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Auditorio Principal
                            </p>
                            <p>
                                Reconocimiento a los ganadores de concursos y a las participaciones destacadas desarrolladas durante el evento.
                            </p>
                        </div>
                    </div>

                    <div class="session-card">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>12:30 - 13:00</span>
                        </div>
                        <div class="session-content">
                            <h3>Cierre Oficial</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Auditorio Principal
                            </p>
                            <p>
                                Despedida institucional y cierre del XV CONAEINGEO – Arequipa 2026.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Download CTA -->
            <div class="download-cta">
                <div class="card">
                    <h2>Descarga el Programa Completo</h2>
                    <p>
                        Obtén el programa detallado en PDF con toda la información del calendario académico, concursos y actividades del congreso.
                    </p>
                    <a href="#" class="btn btn-primary">
                        <i class="fas fa-download"></i>
                        Descargar Programa PDF
                    </a>
                </div>
            </div>
        </div>
    </section>
<style>
    .page-header {
        background: var(--gradient-hero);
        color: var(--color-white);
        padding: 8rem 0 4rem;
        text-align: center;
        margin-top: 80px;
    }

    .page-header h1 {
        color: var(--color-white);
        margin-bottom: 1rem;
    }

    .page-header p {
        font-size: 1.25rem;
        color: rgba(255, 255, 255, 0.9);
        max-width: 600px;
        margin: 0 auto;
    }

    .day-schedule {
        margin-bottom: 4rem;
    }

    .day-header {
        display: flex;
        align-items: center;
        gap: 2rem;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 3px solid var(--color-primary);
    }

    .day-badge {
        background: var(--gradient-primary);
        color: var(--color-white);
        padding: 1.5rem 2rem;
        border-radius: var(--radius-lg);
        text-align: center;
        min-width: 180px;
        box-shadow: var(--shadow-lg);
    }

    .day-number {
        display: block;
        font-size: 1.5rem;
        font-weight: 900;
        font-family: var(--font-heading);
    }

    .day-date {
        display: block;
        font-size: 0.95rem;
        opacity: 0.95;
        margin-top: 0.25rem;
    }

    .day-header h2 {
        color: var(--color-dark);
        margin: 0;
    }

    .sessions {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .session-card {
        background: var(--color-white);
        border-radius: var(--radius-lg);
        padding: 2rem;
        box-shadow: var(--shadow-md);
        display: flex;
        gap: 2rem;
        transition: all var(--transition-normal);
        border-left: 4px solid transparent;
    }

    .session-card:hover {
        box-shadow: var(--shadow-lg);
        transform: translateX(5px);
        border-left-color: var(--color-primary);
    }

    .session-card.highlight {
        border-left-color: var(--color-primary);
        background: linear-gradient(
            to right,
            rgba(217, 119, 6, 0.05),
            var(--color-white)
        );
    }

    .session-time {
        min-width: 140px;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: var(--color-primary);
        font-weight: 600;
        font-family: var(--font-heading);
        font-size: 1.125rem;
    }

    .session-time i {
        font-size: 1.25rem;
    }

    .session-content h3 {
        color: var(--color-dark);
        margin-bottom: 0.75rem;
        font-size: 1.25rem;
    }

    .session-content p {
        margin-bottom: 0.75rem;
    }

    .session-content p:last-child {
        margin-bottom: 0;
    }

    .session-location,
    .session-speaker,
    .session-note {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.95rem;
        color: var(--color-text-light);
    }

    .session-location {
        color: var(--color-accent);
        font-weight: 600;
    }

    .session-speaker {
        color: var(--color-secondary);
        font-weight: 600;
    }

    .session-note {
        background: var(--color-light);
        padding: 0.75rem 1rem;
        border-radius: var(--radius-md);
        color: var(--color-primary);
        font-weight: 600;
        margin-top: 0.75rem;
    }

    .download-cta {
        margin-top: 4rem;
        text-align: center;
    }

    .download-cta .card {
        background: var(--gradient-primary);
        color: var(--color-white);
        padding: 3rem;
        max-width: 600px;
        margin: 0 auto;
    }

    .download-cta h2 {
        color: var(--color-white);
        margin-bottom: 1rem;
    }

    .download-cta p {
        color: rgba(255, 255, 255, 0.95);
        margin-bottom: 2rem;
        font-size: 1.125rem;
    }

    .download-cta .btn {
        background: var(--color-white);
        color: var(--color-primary);
        padding: 1.25rem 3rem;
        font-size: 1.125rem;
    }

    .download-cta .btn:hover {
        background: var(--color-light);
        transform: translateY(-2px);
    }

    .download-cta .btn i {
        margin-right: 0.75rem;
    }

    @media (max-width: 768px) {
        .page-header {
            padding: 6rem 0 3rem;
        }

        .day-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .day-badge {
            width: 100%;
        }

        .session-card {
            flex-direction: column;
            gap: 1rem;
        }

        .session-time {
            min-width: auto;
        }
    }
</style>

</Layout>

<script>
    const buttons = document.querySelectorAll(".filter-btn");
    const sessions = document.querySelectorAll(".session-card");

    buttons.forEach(btn => {
        btn.addEventListener("click", () => {
            const filter = btn.dataset.filter;

            buttons.forEach(b => b.classList.remove("active"));
            btn.classList.add("active");

            sessions.forEach(session => {
                const rawCategories = session.dataset.category || "";
                const categories = rawCategories
                    .split(",")
                    .map(item => item.trim())
                    .filter(Boolean);

                if (filter === "all" || categories.includes(filter)) {
                    session.style.display = "flex";
                } else {
                    session.style.display = "none";
                }
            });
        });
    });
</script>

<style>
    .activity-filters {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        justify-content: center;
        margin-top: 3rem;
        margin-bottom: 3rem;
    }

    .filter-btn {
        background: var(--color-white);
        color: var(--color-primary);
        border: 2px solid var(--color-primary);
        padding: 0.6rem 1.5rem;
        border-radius: 999px;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        transition: all var(--transition-normal);
        box-shadow: var(--shadow-sm);
    }

    .filter-btn:hover {
        background: var(--color-primary);
        color: var(--color-white);
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
    }

    .filter-btn.active {
        background: var(--gradient-primary);
        color: var(--color-white);
        border-color: transparent;
        box-shadow: var(--shadow-lg);
    }

    @media (max-width: 768px) {
        .activity-filters {
            gap: 0.75rem;
        }

        .filter-btn {
            padding: 0.5rem 1.25rem;
            font-size: 0.9rem;
        }
    }
</style>
