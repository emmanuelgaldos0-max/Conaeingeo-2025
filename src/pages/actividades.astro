---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Actividades - CONAEINGEO 2026">
    <!-- Page Header -->
    <section class="page-header">
        <div class="container">
            <h1>Calendario de Actividades</h1>
            <p>Programa completo del congreso - 15 al 18 de Septiembre 2026</p>
        </div>
    </section>


    <!-- FILTERS -->
    <div class="activity-filters">
        <button class="filter-btn active" data-filter="all">Todas</button>
        <button class="filter-btn" data-filter="magistrales">Ponencias Magistrales</button>
        <button class="filter-btn" data-filter="concursos">Concursos</button>
        <button class="filter-btn" data-filter="workshops">Workshops</button>
        <button class="filter-btn" data-filter="tecnica">Visitas Tecnicas</button>
        <button class="filter-btn" data-filter="campo">Salidas de campo</button>
    </div>



    <!-- Schedule Content -->
    <section class="section">
        <div class="container">

            <!-- Day 1 -->
            <div class="day-schedule">
                <div class="day-header">
                    <div class="day-badge">
                        <span class="day-number">DÍA 1</span>
                        <span class="day-date">15 de Septiembre</span>
                    </div>
                    <h2>Inauguración y Conferencias Magistrales</h2>
                </div>

                <div class="sessions">
                    <div class="session-card">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>08:00 - 09:00</span>
                        </div>
                        <div class="session-content">
                            <h3>Registro y Acreditación</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Hall Principal,
                                UNSA
                            </p>
                            <p>
                                Los participantes recibirán sus credenciales, material informativo y orientaciones generales para el desarrollo de las actividades académicas programadas durante el congreso.
                            </p>
                        </div>
                    </div>

                    <div class="session-card highlight">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>09:00 - 10:00</span>
                        </div>
                        <div class="session-content">
                            <h3>Ceremonia de Inauguración</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Auditorio Principal
                            </p>
                            <p class="session-speaker">
                                <i class="fas fa-user"></i> Autoridades UNSA y Comité
                                Organizador
                            </p>
                            <p>
                                Acto protocolar de apertura con palabras de bienvenida de las autoridades de la UNSA y la presentación oficial del XV CONAEINGEO – Arequipa 2026.
                            </p>
                        </div>
                    </div>

                    <div class="session-card highlight" data-category="magistrales">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>10:00 - 11:30</span>
                        </div>
                        <div class="session-content">
                            <h3>
                                Conferencia Magistral: Estado Actual de la
                                Minería en Perú
                            </h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Auditorio Principal
                            </p>
                            <p class="session-speaker">
                                <i class="fas fa-user"></i> Dr. Carlos Mendoza - Ingeniero
                                de Minas Senior
                            </p>
                            <p>
                                Espacio orientado al análisis del contexto actual del sector minero en el Perú, sus principales desafíos y las oportunidades de innovación y desarrollo para los próximos años.
                            </p>
                        </div>
                    </div>

                    <div class="session-card">
                        <div class="session-time" >
                            <i class="fas fa-clock"></i>
                            <span>11:30 - 12:00</span>
                        </div>
                        <div class="session-content">
                            <h3>Coffee Break</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Área de Networking
                            </p>
                            <p>
                                Espacio destinado al refrigerio, descanso e interacción entre participantes, ponentes y organizadores.
                            </p>
                        </div>
                    </div>

                    <div class="session-card" data-category="workshops">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>12:00 - 13:30</span>
                        </div>
                        <div class="session-content">
                            <h3>
                                Panel: Desafíos de la Industria Minera Moderna
                            </h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Auditorio Principal
                            </p>
                            <p class="session-speaker">
                                <i class="fas fa-users"></i> Panel de 5 expertos nacionales
                                e internacionales
                            </p>
                            <p>
                                Mesa de análisis sobre sostenibilidad, innovación tecnológica, regulación y perspectivas de desarrollo para la minería contemporánea.
                            </p>
                        </div>
                    </div>

                    <div class="session-card">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>13:30 - 15:00</span>
                        </div>
                        <div class="session-content">
                            <h3>Almuerzo</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Comedor Universitario
                            </p>
                        </div>
                    </div>

                    <div class="session-card">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>15:00 - 17:00</span>
                        </div>
                        <div class="session-content">
                            <h3>Sesiones Paralelas - Track A y B</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Salas A y B
                            </p>
                            <p>
                                <strong>Track A:</strong> Presentación de experiencias, estudios y casos aplicados en proyectos mineros y geológicos.<br />
                                <strong>Track B:</strong> Exposición de herramientas, metodologías e innovaciones tecnológicas vinculadas a la exploración mineral.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Day 2 -->
            <div class="day-schedule">
                <div class="day-header">
                    <div class="day-badge">
                        <span class="day-number">DÍA 2</span>
                        <span class="day-date">16 de Septiembre</span>
                    </div>
                    <h2>Innovación Tecnológica y Talleres</h2>
                </div>

                <div class="sessions">
                    <div class="session-card highlight">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>09:00 - 11:00</span>
                        </div>
                        <div class="session-content">
                            <h3>
                                Taller: Automatización en Minería Subterránea
                            </h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Laboratorio
                                de Tecnología
                            </p>
                            <p class="session-speaker">
                                <i class="fas fa-user"></i> Ing. Roberto Silva - Especialista
                                en Automatización
                            </p>
                            <p>
                                Taller práctico enfocado en automatización, monitoreo y control de procesos aplicados al contexto minero y a la mejora de la eficiencia operativa.
                            </p>
                            <p class="session-note">
                                <i class="fas fa-info-circle"></i> Cupos limitados
                                - Requiere inscripción previa
                            </p>
                        </div>
                    </div>

                    <div class="session-card">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>11:00 - 11:30</span>
                        </div>
                        <div class="session-content">
                            <h3>Coffee Break</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Área de Networking
                            </p>
                        </div>
                    </div>

                    <div class="session-card highlight">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>11:30 - 13:00</span>
                        </div>
                        <div class="session-content">
                            <h3>
                                Conferencia: Inteligencia Artificial en
                                Exploración Mineral
                            </h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Auditorio Principal
                            </p>
                            <p class="session-speaker">
                                <i class="fas fa-user"></i> Dra. María Torres - Geóloga
                                Especialista
                            </p>
                            <p>
                                Conferencia orientada a mostrar aplicaciones de inteligencia artificial y aprendizaje automático en exploración geológica, análisis de datos y apoyo a la toma de decisiones.
                            </p>
                        </div>
                    </div>

                    <div class="session-card">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>13:00 - 14:30</span>
                        </div>
                        <div class="session-content">
                            <h3>Almuerzo</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Comedor Universitario
                            </p>
                        </div>
                    </div>

                    <div class="session-card">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>14:30 - 16:30</span>
                        </div>
                        <div class="session-content">
                            <h3>
                                Showcase: Nuevas Tecnologías de Procesamiento
                                Mineral
                            </h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Sala de Exposiciones
                            </p>
                            <p>
                                Espacio de exhibición y demostración de soluciones, equipos y metodologías vinculadas al procesamiento mineral y la innovación en la industria.
                            </p>
                        </div>
                    </div>

                    <div class="session-card">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>16:30 - 18:00</span>
                        </div>
                        <div class="session-content">
                            <h3>
                                Mesa Redonda: Transformación Digital en Minería
                            </h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Sala de Conferencias
                            </p>
                            <p>
                                Conversatorio orientado a reflexionar sobre transformación digital, automatización, análisis de datos y su impacto en la cadena de valor minera.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Day 3 -->
            <div class="day-schedule">
                <div class="day-header">
                    <div class="day-badge">
                        <span class="day-number">DÍA 3</span>
                        <span class="day-date">17 de Septiembre</span>
                    </div>
                    <h2>Sostenibilidad y Responsabilidad Ambiental</h2>
                </div>

                <div class="sessions">
                    <div class="session-card highlight">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>09:00 - 11:00</span>
                        </div>
                        <div class="session-content">
                            <h3>Panel: Minería Verde y Economía Circular</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Auditorio Principal
                            </p>
                            <p class="session-speaker">
                                <i class="fas fa-users"></i> Panel de expertos en
                                sostenibilidad
                            </p>
                            <p>
                                Diálogo especializado sobre sostenibilidad, economía circular, buenas prácticas ambientales y retos actuales para una minería responsable.
                            </p>
                        </div>
                    </div>

                    <div class="session-card">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>11:00 - 11:30</span>
                        </div>
                        <div class="session-content">
                            <h3>Coffee Break</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Área de Networking
                            </p>
                        </div>
                    </div>

                    <div class="session-card highlight">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>11:30 - 13:30</span>
                        </div>
                        <div class="session-content">
                            <h3>
                                Taller: Gestión de Recursos Hídricos en Minería
                            </h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Sala de Talleres
                            </p>
                            <p class="session-speaker">
                                <i class="fas fa-user"></i> Ing. Ana Martínez - Especialista
                                Ambiental
                            </p>
                            <p>
                                Sesión técnica orientada a compartir criterios, estrategias y experiencias sobre gestión eficiente del recurso hídrico en actividades mineras.
                            </p>
                            <p class="session-note">
                                <i class="fas fa-info-circle"></i> Incluye material
                                de trabajo
                            </p>
                        </div>
                    </div>

                    <div class="session-card">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>13:30 - 15:00</span>
                        </div>
                        <div class="session-content">
                            <h3>Almuerzo</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Comedor Universitario
                            </p>
                        </div>
                    </div>

                    <div class="session-card highlight">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>15:00 - 17:00</span>
                        </div>
                        <div class="session-content">
                            <h3>
                                Conferencia: Relaciones Comunitarias y Licencia
                                Social
                            </h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Auditorio Principal
                            </p>
                            <p class="session-speaker">
                                <i class="fas fa-user"></i> Dr. Luis Fernández - Experto
                                en Responsabilidad Social
                            </p>
                            <p>
                                Presentación sobre estrategias de relacionamiento comunitario, comunicación efectiva y construcción de confianza entre empresa, territorio y sociedad.
                            </p>
                        </div>
                    </div>

                    <div class="session-card">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>17:00 - 18:00</span>
                        </div>
                        <div class="session-content">
                            <h3>Sesión de Posters</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Hall de Exposiciones
                            </p>
                            <p>
                                Espacio para la difusión de investigaciones, estudios de caso y proyectos académicos desarrollados por estudiantes y jóvenes investigadores.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Day 4 -->
            <div class="day-schedule">
                <div class="day-header">
                    <div class="day-badge">
                        <span class="day-number">DÍA 4</span>
                        <span class="day-date">18 de Septiembre</span>
                    </div>
                    <h2>Networking y Clausura</h2>
                </div>

                <div class="sessions">
                    <div class="session-card">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>09:00 - 11:00</span>
                        </div>
                        <div class="session-content">
                            <h3>Presentación de Casos de Éxito</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Auditorio Principal
                            </p>
                            <p>
                                Presentación de experiencias destacadas, buenas prácticas y aprendizajes obtenidos en proyectos representativos del sector.
                            </p>
                        </div>
                    </div>

                    <div class="session-card">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>11:00 - 11:30</span>
                        </div>
                        <div class="session-content">
                            <h3>Coffee Break</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Área de Networking
                            </p>
                        </div>
                    </div>

                    <div class="session-card highlight">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>11:30 - 13:00</span>
                        </div>
                        <div class="session-content">
                            <h3>Sesión de Networking Empresarial</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Sala de Networking
                            </p>
                            <p>
                                Espacio de articulación entre estudiantes, egresados, profesionales e instituciones para fortalecer redes de contacto y futuras colaboraciones.
                            </p>
                            <p class="session-note">
                                <i class="fas fa-info-circle"></i> Incluye almuerzo
                                de networking
                            </p>
                        </div>
                    </div>

                    <div class="session-card">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>13:00 - 14:30</span>
                        </div>
                        <div class="session-content">
                            <h3>Almuerzo de Networking</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Salón de Eventos
                            </p>
                        </div>
                    </div>

                    <div class="session-card highlight">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>15:00 - 16:30</span>
                        </div>
                        <div class="session-content">
                            <h3>Ceremonia de Clausura</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Auditorio Principal
                            </p>
                            <p>
                                Acto de cierre del congreso con balance general de actividades, reconocimientos a participantes y entrega simbólica de certificados.
                            </p>
                        </div>
                    </div>

                    <div class="session-card">
                        <div class="session-time">
                            <i class="fas fa-clock"></i>
                            <span>16:30 - 17:00</span>
                        </div>
                        <div class="session-content">
                            <h3>Brindis de Despedida</h3>
                            <p class="session-location">
                                <i class="fas fa-map-marker-alt"></i> Área Social
                            </p>
                            <p>
                                Momento final de confraternidad y despedida entre participantes, organizadores e invitados.
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Download CTA -->
            <div class="download-cta">
                <div class="card">
                    <h2>Descarga el Programa Completo</h2>
                    <p>
                        Obtén el programa detallado en PDF con toda la
                        información de ponentes, talleres y actividades.
                    </p>
                    <a href="#" class="btn btn-primary">
                        <i class="fas fa-download"></i>
                        Descargar Programa PDF
                    </a>
                </div>
            </div>
        </div>
    </section>
<style>
    .page-header {
        background: var(--gradient-hero);
        color: var(--color-white);
        padding: 8rem 0 4rem;
        text-align: center;
        margin-top: 80px;
    }

    .page-header h1 {
        color: var(--color-white);
        margin-bottom: 1rem;
    }

    .page-header p {
        font-size: 1.25rem;
        color: rgba(255, 255, 255, 0.9);
        max-width: 600px;
        margin: 0 auto;
    }

    .day-schedule {
        margin-bottom: 4rem;
    }

    .day-header {
        display: flex;
        align-items: center;
        gap: 2rem;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 3px solid var(--color-primary);
    }

    .day-badge {
        background: var(--gradient-primary);
        color: var(--color-white);
        padding: 1.5rem 2rem;
        border-radius: var(--radius-lg);
        text-align: center;
        min-width: 180px;
        box-shadow: var(--shadow-lg);
    }

    .day-number {
        display: block;
        font-size: 1.5rem;
        font-weight: 900;
        font-family: var(--font-heading);
    }

    .day-date {
        display: block;
        font-size: 0.95rem;
        opacity: 0.95;
        margin-top: 0.25rem;
    }

    .day-header h2 {
        color: var(--color-dark);
        margin: 0;
    }

    .sessions {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .session-card {
        background: var(--color-white);
        border-radius: var(--radius-lg);
        padding: 2rem;
        box-shadow: var(--shadow-md);
        display: flex;
        gap: 2rem;
        transition: all var(--transition-normal);
        border-left: 4px solid transparent;
    }

    .session-card:hover {
        box-shadow: var(--shadow-lg);
        transform: translateX(5px);
        border-left-color: var(--color-primary);
    }

    .session-card.highlight {
        border-left-color: var(--color-primary);
        background: linear-gradient(
            to right,
            rgba(217, 119, 6, 0.05),
            var(--color-white)
        );
    }

    .session-time {
        min-width: 140px;
        display: flex;
        align-items: center;
        gap: 0.75rem;
        color: var(--color-primary);
        font-weight: 600;
        font-family: var(--font-heading);
        font-size: 1.125rem;
    }

    .session-time i {
        font-size: 1.25rem;
    }

    .session-content h3 {
        color: var(--color-dark);
        margin-bottom: 0.75rem;
        font-size: 1.25rem;
    }

    .session-content p {
        margin-bottom: 0.75rem;
    }

    .session-content p:last-child {
        margin-bottom: 0;
    }

    .session-location,
    .session-speaker,
    .session-note {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        font-size: 0.95rem;
        color: var(--color-text-light);
    }

    .session-location {
        color: var(--color-accent);
        font-weight: 600;
    }

    .session-speaker {
        color: var(--color-secondary);
        font-weight: 600;
    }

    .session-note {
        background: var(--color-light);
        padding: 0.75rem 1rem;
        border-radius: var(--radius-md);
        color: var(--color-primary);
        font-weight: 600;
        margin-top: 0.75rem;
    }

    .download-cta {
        margin-top: 4rem;
        text-align: center;
    }

    .download-cta .card {
        background: var(--gradient-primary);
        color: var(--color-white);
        padding: 3rem;
        max-width: 600px;
        margin: 0 auto;
    }

    .download-cta h2 {
        color: var(--color-white);
        margin-bottom: 1rem;
    }

    .download-cta p {
        color: rgba(255, 255, 255, 0.95);
        margin-bottom: 2rem;
        font-size: 1.125rem;
    }

    .download-cta .btn {
        background: var(--color-white);
        color: var(--color-primary);
        padding: 1.25rem 3rem;
        font-size: 1.125rem;
    }

    .download-cta .btn:hover {
        background: var(--color-light);
        transform: translateY(-2px);
    }

    .download-cta .btn i {
        margin-right: 0.75rem;
    }

    @media (max-width: 768px) {
        .page-header {
            padding: 6rem 0 3rem;
        }

        .day-header {
            flex-direction: column;
            align-items: flex-start;
        }

        .day-badge {
            width: 100%;
        }

        .session-card {
            flex-direction: column;
            gap: 1rem;
        }

        .session-time {
            min-width: auto;
        }
    }
</style>


</Layout>

<script>
    const buttons = document.querySelectorAll(".filter-btn");
    const sessions = document.querySelectorAll(".session-card");

    buttons.forEach(btn => {
        btn.addEventListener("click", () => {
            const filter = btn.dataset.filter;

            buttons.forEach(b => b.classList.remove("active"));
            btn.classList.add("active");

            sessions.forEach(session => {
                if (filter === "all" || session.dataset.category === filter) {
                    session.style.display = "flex";
                } else {
                    session.style.display = "none";
                }
            });
        });
    });
</script>
















